---
import '../styles/colors_and_type.css';
import '../styles/components.css';
import '../styles/site.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  locale: 'en' | 'th';
  /** Canonical path including locale, e.g. '/en/' or '/en/ayutthaya/'. */
  canonicalPath: string;
  /** Page-specific OG image path (relative, e.g. '/og/ayutthaya.png'). Defaults to '/og/default.png'. */
  ogImage?: string;
}
const { title, description, locale, canonicalPath, ogImage = '/og/default.png' } = Astro.props;
const siteUrl = 'https://thailandliveabilityindex.com';
const pathInLocale = canonicalPath.replace(/^\/(en|th)/, '') || '/';
const enHref = `${siteUrl}/en${pathInLocale}`;
const thHref = `${siteUrl}/th${pathInLocale}`;
const ogImageAbs = `${siteUrl}${ogImage}`;
---
<!doctype html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={`${siteUrl}${canonicalPath}`} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  {/* Open Graph */}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={`${siteUrl}${canonicalPath}`} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Thailand Liveability Index" />
  <meta property="og:locale" content={locale === 'th' ? 'th_TH' : 'en_US'} />
  <meta property="og:image" content={ogImageAbs} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:alt" content={title} />

  {/* Twitter Card */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbs} />

  <link rel="alternate" hreflang="en" href={enHref} />
  <link rel="alternate" hreflang="th" href={thHref} />
  <link rel="alternate" hreflang="x-default" href={enHref} />
</head>
<body>
  <a class="tli-skip" href="#main">Skip to main content</a>
  <Nav locale={locale} pathInLocale={pathInLocale} />
  <main id="main">
    <slot />
  </main>
  <Footer locale={locale} />
</body>
</html>
