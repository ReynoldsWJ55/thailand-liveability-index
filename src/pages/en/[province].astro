import Site from '../../layouts/Site.astro';
import Hero from '../../components/Hero.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import IndicatorTable from '../../components/IndicatorTable.astro';
import UrbanNaNote from '../../components/UrbanNaNote.astro';
import { CATEGORY_ORDER, CHROME } from '../../data/lookups';
import scoresData from '../../data/scores.json';
import type { Province, ScoresFile } from '../../data/types';

export function getStaticPaths() {
  const data = scoresData as ScoresFile;
  return data.provinces.map((p) => ({
    params: { province: p.id },
    props: { province: p },
  }));
}

const { province } = Astro.props as { province: Province };
const locale = 'en' as const;
const C = CHROME[locale];

const cats = CATEGORY_ORDER.map((id) => province.categories[id]);
const totalIndicators = cats.reduce((acc, c) => acc + c.indicator_count, 0);

// Determine the freshest as_of across all categories — drives the hero AS OF.
const freshestAsOf = cats
  .map((c) => c.freshest_as_of)
  .sort()
  .reverse()[0];

const description =
  province.composite === null || province.floored
    ? `${province.name_en} (rank ${province.rank} of 77). Composite floored at 0 by ${province.floored_by ?? 'an indicator'} — non-substitutability locks the geometric mean.`
    : `${province.name_en} composite liveability score ${province.composite} of 100, rank ${province.rank} of 77, ${province.category_count_full}/7 categories with full coverage.`;

// JSON-LD Dataset schema for AI/SEO citability — same pattern as zone + indicator pages.
// Carries province name in EN + TH plus category labels as keywords so AI search
// engines (Perplexity, ChatGPT browse, Claude, Gemini) can match queries against
// this province's data offering.
const provinceDatasetSchema = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: `${province.name_en} liveability score — Thailand Liveability Index`,
  alternateName: `${province.name_th} ดัชนีคุณภาพการอยู่อาศัย`,
  description,
  url: `https://thailandliveabilityindex.com/en/${province.id}/`,
  isPartOf: {
    '@type': 'Dataset',
    name: 'Thailand Liveability Index',
    url: 'https://thailandliveabilityindex.com/',
  },
  variableMeasured: cats.map((cat) => ({
    '@type': 'PropertyValue',
    name: cat.id,
    value: cat.score,
    description: `${cat.id} category score (0-100)`,
  })),
  spatialCoverage: {
    '@type': 'Place',
    name: `${province.name_en}, Thailand`,
    alternateName: province.name_th,
  },
  temporalCoverage: freshestAsOf || '2024',
  creator: {
    '@type': 'Person',
    name: 'William J. Reynolds',
    sameAs: 'https://orcid.org/0009-0005-1217-7465',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Thailand Liveability Index',
    url: 'https://thailandliveabilityindex.com/',
  },
  license: 'https://creativecommons.org/licenses/by-nc/4.0/',
  keywords: [
    'Thailand', 'liveability', 'province',
    province.name_en, province.name_th,
    `${province.name_en} air quality`,
    `${province.name_en} healthcare`,
    `${province.name_en} cost of living`,
    `${province.name_en} safety`,
    `living in ${province.name_en}`,
    `${province.name_en} composite score`,
  ],
};
---
<Site
  title={`${province.name_en} · Thailand Liveability Index`}
  description={description}
  locale={locale}
  canonicalPath={`/en/${province.id}/`}
  ogImage={`/og/${province.id}.png`}
>
  <script type="application/ld+json" set:html={JSON.stringify(provinceDatasetSchema)} />
  <Hero province={province} locale={locale} asOf={freshestAsOf} />

  <section class="section" aria-labelledby="cat-title">
    <div class="section__head">
      <h2 class="section__title" id="cat-title">{C.byCategory}</h2>
      <span class="section__sub">
        7 categories · {totalIndicators} indicator{totalIndicators === 1 ? '' : 's'}
      </span>
    </div>
    <div class="cat-grid">
      {cats.map((cat) => (
        <CategoryCard
          category={cat}
          locale={locale}
          isFloor={province.floored && province.floored_by === cat.id}
        />
      ))}
    </div>
  </section>

  <UrbanNaNote province={province} locale={locale} />

  {cats.map((cat) => (
    <IndicatorTable
      category={cat}
      locale={locale}
      isFloor={province.floored && province.floored_by === cat.id}
      provinceId={province.id}
    />
  ))}
</Site>
