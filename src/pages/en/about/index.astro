---
// Copyright (c) 2026 Will Reynolds
// SPDX-License-Identifier: MIT
import Site from '../../../layouts/Site.astro';
import ProvenanceChip from '../../../components/ProvenanceChip.astro';
import Lucide from '../../../components/Lucide.astro';
import scoresData from '../../../data/scores.json';
import type { ScoresFile, Indicator, CategoryId } from '../../../data/types';
import { CATEGORIES, CATEGORY_ORDER } from '../../../data/lookups';

const data = scoresData as ScoresFile;

// Build a per-source aggregate from every indicator on every province.
interface SourceAggregate {
  source: string;
  source_url: string;
  indicator_ids: Set<string>;
  categories: Set<CategoryId>;
  freshest_as_of: string;
  oldest_as_of: string;
  province_count: number;
  has_stale: boolean;
  has_inherited: boolean;
}

const sources = new Map<string, SourceAggregate>();

for (const province of data.provinces) {
  for (const cat of Object.values(province.categories)) {
    for (const ind of cat.indicators as Indicator[]) {
      let agg = sources.get(ind.source);
      if (!agg) {
        agg = {
          source: ind.source,
          source_url: ind.source_url,
          indicator_ids: new Set(),
          categories: new Set(),
          freshest_as_of: ind.as_of,
          oldest_as_of: ind.as_of,
          province_count: 0,
          has_stale: false,
          has_inherited: false,
        };
        sources.set(ind.source, agg);
      }
      agg.indicator_ids.add(ind.id);
      agg.categories.add(cat.id);
      if (ind.as_of > agg.freshest_as_of) agg.freshest_as_of = ind.as_of;
      if (ind.as_of < agg.oldest_as_of) agg.oldest_as_of = ind.as_of;
      agg.province_count += 1;
      if (ind.quality_flag === 'stale') agg.has_stale = true;
      if (ind.quality_flag === 'inherited') agg.has_inherited = true;
    }
  }
}

const sourceList = Array.from(sources.values()).sort((a, b) =>
  a.source.localeCompare(b.source),
);

const indicatorCount = new Set(
  data.provinces.flatMap((p) =>
    Object.values(p.categories).flatMap((c) => c.indicators.map((i) => i.id)),
  ),
).size;

// Pre-compute per-category indicator lists in the frontmatter (TS plays nicer
// here than inside JSX expressions where Set<string> reads as a JSX tag).
const categoryIndicators = CATEGORY_ORDER.map((cid) => {
  const ids = new Set<string>();
  const labels = new Map<string, string>();
  for (const province of data.provinces) {
    const c = province.categories[cid];
    if (!c) continue;
    for (const ind of c.indicators) {
      ids.add(ind.id);
      labels.set(ind.id, ind.label_en);
    }
  }
  return { id: cid, indicators: Array.from(ids), labels };
});
---
<Site
  title="About · Thailand Liveability Index"
  description="The data sources behind TLI — every indicator, every source, every license."
  locale="en"
  canonicalPath="/en/about/"
  ogImage="/og/about.png"
>
  <article class="methodology">
    <header class="methodology__head">
      <p class="tli-eyebrow">About · sources</p>
      <h1 class="methodology__title">The data behind TLI</h1>
      <p class="methodology__lede">
        Every indicator on this site derives from public Thai government data, open scientific
        datasets, or other openly-licensed research. This page lists every source, the indicators
        we draw from each, and the freshest as-of date currently in our build.
      </p>
      <div class="methodology__meta">
        <ProvenanceChip variant="fresh" icon="calendar">
          BUILD {data.generated_at.slice(0, 10).toUpperCase()}
        </ProvenanceChip>
        <ProvenanceChip icon="badge-check">METHODOLOGY {data.methodology_version.toUpperCase()}</ProvenanceChip>
        <ProvenanceChip icon="book-open">CC BY 4.0</ProvenanceChip>
      </div>
    </header>

    <section class="methodology__section" id="overview">
      <h2 class="methodology__h2">At a glance</h2>
      <ul class="about-stats">
        <li>
          <span class="about-stats__num tli-num">{data.provinces.length}</span>
          <span class="about-stats__label">provinces in this build</span>
        </li>
        <li>
          <span class="about-stats__num tli-num">{indicatorCount}</span>
          <span class="about-stats__label">distinct indicators</span>
        </li>
        <li>
          <span class="about-stats__num tli-num">{sourceList.length}</span>
          <span class="about-stats__label">primary sources</span>
        </li>
        <li>
          <span class="about-stats__num tli-num">7</span>
          <span class="about-stats__label">categories</span>
        </li>
      </ul>
    </section>

    <section class="methodology__section" id="sources">
      <h2 class="methodology__h2">Primary sources</h2>
      <p>
        Each row lists a source, the categories of TLI it feeds, the indicator(s) drawn from it,
        and the freshness of the data in this build. Click through to the source for the canonical
        record.
      </p>
      <ul class="about-sources">
        {sourceList.map((s) => (
          <li class="about-source">
            <div class="about-source__head">
              <a href={s.source_url} target="_blank" rel="noopener noreferrer" class="about-source__name">
                {s.source}
                <Lucide name="external-link" size={12} class="tli-citations__icon" />
              </a>
              <div class="about-source__chips">
                <ProvenanceChip variant={s.has_stale ? 'stale' : 'fresh'} icon="calendar">
                  AS OF {s.freshest_as_of}
                </ProvenanceChip>
                {s.has_stale && <ProvenanceChip variant="stale" icon="clock-alert">STALE INDICATOR</ProvenanceChip>}
              </div>
            </div>
            <dl class="about-source__meta">
              <div>
                <dt>Categories fed</dt>
                <dd>
                  {Array.from(s.categories).map((cid, i) => (
                    <>
                      {i > 0 && ' · '}
                      <span class="about-source__cat">
                        <span class:list={['tli-cat-dot', CATEGORIES[cid].cssClass]} aria-hidden="true"></span>
                        {CATEGORIES[cid].label_en}
                      </span>
                    </>
                  ))}
                </dd>
              </div>
              <div>
                <dt>Indicators</dt>
                <dd class="tli-num">{s.indicator_ids.size}</dd>
              </div>
              <div>
                <dt>Coverage</dt>
                <dd class="tli-num">
                  {s.province_count} province-rows
                </dd>
              </div>
            </dl>
          </li>
        ))}
      </ul>
    </section>

    <section class="methodology__section" id="categories">
      <h2 class="methodology__h2">Categories and the indicators in this build</h2>
      <p>
        TLI's seven categories, and the indicators currently wired into each. The full
        indicator framework includes ~22 indicators; some are still in development and will land
        as the data pipeline matures.
      </p>
      <ul class="about-categories">
        {categoryIndicators.map((entry) => {
          const cat = CATEGORIES[entry.id];
          return (
            <li class="about-category">
              <h3 class="about-category__name">
                <span class:list={['tli-cat-dot', cat.cssClass]} aria-hidden="true"></span>
                {cat.label_en}
              </h3>
              <ul class="about-category__indicators">
                {entry.indicators.map((id) => (
                  <li>
                    <span class="about-category__indicator-id tli-num">{id}</span>
                    <span class="about-category__indicator-label">{entry.labels.get(id)}</span>
                  </li>
                ))}
              </ul>
            </li>
          );
        })}
      </ul>
    </section>

    <section class="methodology__section" id="licensing">
      <h2 class="methodology__h2">Licensing</h2>
      <p>
        TLI's <strong>methodology, indicator dictionary, and category structure</strong> are
        published under <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener noreferrer">CC BY 4.0</a>.
        You may copy, adapt, redistribute, and build on these — including commercially —
        with attribution to "Thailand Liveability Index, Reynolds 2026".
      </p>
      <p>
        The <strong>frontend code</strong> in this repository is published under the
        <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener noreferrer">MIT License</a>.
        The <strong>raw underlying datasets</strong> remain the property of their original publishers
        and carry their own licenses; see each source for terms.
      </p>
      <p>
        The composite TLI score itself, and the exact normalisation goalposts and weights, are
        published openly. Future iterations may include downloadable CSV exports of the score
        table for academic use.
      </p>
    </section>

    <section class="methodology__section" id="cite">
      <h2 class="methodology__h2">How to cite</h2>
      <pre class="methodology__formula">
Reynolds, W. (2026). Thailand Liveability Index (Version {data.methodology_version}) [Data set].
https://thailandliveabilityindex.com</pre>
    </section>
  </article>
</Site>
