import Site from '../../layouts/Site.astro';
import HomeHero from '../../components/HomeHero.astro';
import TliMap from '../../components/TliMap.astro';
import CuratedRow from '../../components/CuratedRow.astro';
import Controls from '../../components/Controls.astro';
import ProvinceGrid from '../../components/ProvinceGrid.astro';
import ProvenanceChip from '../../components/ProvenanceChip.astro';
import Lucide from '../../components/Lucide.astro';
import scoresData from '../../data/scores.json';
import type { ScoresFile } from '../../data/types';
import { CHROME } from '../../data/lookups';

const data = scoresData as ScoresFile;
const provinces = data.provinces;
const C = CHROME.en;

// Latest as_of across all categories — drives the home AS OF chip.
const asOfDates = provinces.flatMap((p) =>
  Object.values(p.categories).map((c) => c.freshest_as_of),
);
const latestAsOf = asOfDates.sort().at(-1) ?? data.generated_at.slice(0, 10);
const asOfDisplay = new Date(latestAsOf).toLocaleDateString('en-US', {
  month: 'short',
  year: 'numeric',
}).toUpperCase();

// Citation sources (deduped, in encounter order).
const sourceSet = new Set<string>();
provinces.forEach((p) =>
  Object.values(p.categories).forEach((c) =>
    c.indicators.forEach((i) => sourceSet.add(i.source)),
  ),
);
const sources = Array.from(sourceSet).slice(0, 6).join(' · ');
---
<Site
  title={C.homeTitle}
  description={C.homeDescription}
  locale="en"
  canonicalPath="/en/"
  ogImage="/og/home.png"
>
  <HomeHero locale="en" asOf={asOfDisplay} />

  <section class="home-section" aria-labelledby="map-section-title">
    <header class="home-section__head">
      <div>
        <h2 class="home-section__title" id="map-section-title">{C.thailandAtAGlance}</h2>
        <p class="home-section__sub">{C.thailandAtAGlanceSub}</p>
      </div>
      <ProvenanceChip icon="badge-check">
        Choropleth · 77 provinces
      </ProvenanceChip>
    </header>
    <TliMap provinces={provinces} locale="en" />
    <div class="home-citations">
      {sources && <span>SOURCE · {sources.toUpperCase()}</span>}
      <span>{C.asOf} · {asOfDisplay}</span>
      <a href="/en/methodology/" class="home-citations__link">
        <Lucide name="book-open" size={12} class="tli-citations__icon" />
        METHODOLOGY →
      </a>
    </div>
  </section>

  <section class="home-section" aria-labelledby="curated-section-title">
    <header class="home-section__head">
      <div>
        <h2 class="home-section__title" id="curated-section-title">{C.curatedTitle}</h2>
        <p class="home-section__sub">{C.curatedSub}</p>
      </div>
      <ProvenanceChip icon="badge-check">{C.curatedTag}</ProvenanceChip>
    </header>
    <CuratedRow provinces={provinces} locale="en" />
  </section>

  <section class="home-section" aria-labelledby="all77-section-title">
    <header class="home-section__head">
      <div>
        <h2 class="home-section__title" id="all77-section-title">{C.all77Title}</h2>
        <p class="home-section__sub">{C.all77Sub}</p>
      </div>
    </header>
    <Controls locale="en" total={provinces.length} />
    <ProvinceGrid provinces={provinces} locale="en" />
    <div class="home-citations">
      <span>{C.citationsCompositeMethod.toUpperCase()}</span>
      <span>{C.citationsScale.toUpperCase()}</span>
      <a href="/en/methodology/#composite" class="home-citations__link">
        <Lucide name="book-open" size={12} class="tli-citations__icon" />
        {C.howCompositeBuilt.toUpperCase()}
      </a>
    </div>
  </section>
</Site>
