---
import Site from '../../layouts/Site.astro';
import scoresData from '../../data/scores.json';
import type { ScoresFile } from '../../data/types';

const data = scoresData as ScoresFile;
const provinces = [...data.provinces].sort((a, b) => a.rank - b.rank);
const generatedDate = data.generated_at.slice(0, 10);
---
<Site
  title="Thailand Liveability Index"
  description="A research-grade composite index ranking liveability across all 77 Thai provinces. Seven categories, transparent methodology, full provenance."
  locale="en"
  canonicalPath="/en/"
>
  <p class="tli-eyebrow">SCAFFOLD · ITERATION 2 · DATA PIPELINE WIRED</p>
  <h1 class="tli-h1">Thailand Liveability Index</h1>
  <p class="tli-lede">
    A composite liveability score for each of Thailand’s 77 provinces — seven categories,
    transparent methodology, full provenance on every number.
  </p>

  <p class="tli-caption" style="margin-top: var(--sp-6);">
    Data generated <span class="tli-num">{generatedDate}</span> ·
    methodology <span class="tli-num">{data.methodology_version}</span> ·
    source <span class="tli-mono">{data.source_manifest}</span>
  </p>

  <h2 class="tli-h3" style="margin-top: var(--sp-12); margin-bottom: var(--sp-3);">
    Sample provinces
    <span class="tli-eyebrow" style="margin-left: var(--sp-2);">{provinces.length} of 77</span>
  </h2>
  <p class="tli-body-sm" style="margin-bottom: var(--sp-6);">
    The full 77-province dataset arrives from R2 in CI; this page is currently
    rendering a 5-province sample shipped with the repo. The grid, the map,
    and individual province pages land in subsequent iterations.
  </p>

  <ul class="tli-province-list">
    {provinces.map((p) => (
      <li class="tli-province-row">
        <span class="tli-province-row__rank tli-num">{p.rank}</span>
        <span class={`tli-province-row__score tli-num${p.floored ? ' is-floored' : ''}`}>
          {p.floored ? 'FL' : p.composite}
        </span>
        <span class="tli-province-row__name">{p.name_en}</span>
        <span class="tli-province-row__region tli-eyebrow">{p.region}</span>
        {p.floored && (
          <span class="tli-prov tli-prov-missing">FLOORED · {p.floored_by?.toUpperCase()}</span>
        )}
      </li>
    ))}
  </ul>
</Site>
