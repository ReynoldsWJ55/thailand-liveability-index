---
// Copyright (c) 2026 Will Reynolds
// SPDX-License-Identifier: MIT
import Site from '../../../layouts/Site.astro';
import Lucide from '../../../components/Lucide.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ProvenanceChip from '../../../components/ProvenanceChip.astro';
import indicatorMeta from '../../../data/indicator-meta.json';
import scoresData from '../../../data/scores.json';
import { CATEGORIES, SLUG_MAP, indicatorDirection, directionPhrase } from '../../../data/lookups';
import type { CategoryId, ScoresFile, Indicator } from '../../../data/types';

interface IndicatorMetaShape {
  id: string;
  label_en: string;
  label_th: string;
  unit: string;
  source: string;
  source_url: string;
  source_description?: string;
  category_phase2: string;
  category: CategoryId;
  weight: number;
}

interface ProvinceRow {
  id: string;
  name_en: string;
  name_th: string;
  raw: number;
  score: number;
  as_of: string;
}

export function getStaticPaths() {
  const meta = indicatorMeta as Record<string, IndicatorMetaShape>;
  return Object.values(meta).map((m) => ({
    params: { id: SLUG_MAP[m.id] ?? m.id },
    props: { m, slug: SLUG_MAP[m.id] ?? m.id },
  }));
}

const { m, slug } = Astro.props as { m: IndicatorMetaShape; slug: string };
const data = scoresData as ScoresFile;

// Sibling indicators in the same category — hub-and-spoke linking.
const allMeta = indicatorMeta as Record<string, IndicatorMetaShape>;
const siblings = Object.values(allMeta)
  .filter((x) => x.category === m.category && x.id !== m.id)
  .sort((a, b) => a.label_th.localeCompare(b.label_th, 'th'));

const rows: ProvinceRow[] = [];
let freshestAsOf = '';
for (const p of data.provinces) {
  for (const cat of Object.values(p.categories)) {
    for (const ind of cat.indicators as Indicator[]) {
      if (ind.id === m.id) {
        rows.push({
          id: p.id,
          name_en: p.name_en,
          name_th: p.name_th,
          raw: ind.value,
          score: ind.raw_score,
          as_of: ind.as_of,
        });
        if (ind.as_of && ind.as_of > freshestAsOf) freshestAsOf = ind.as_of;
      }
    }
  }
}
const sorted = [...rows].sort((a, b) => b.score - a.score);
const top = sorted.slice(0, 5);
const bottom = sorted.slice(-5).reverse();
const hasData = rows.length > 0;
const median = sorted.length > 0 ? sorted[Math.floor(sorted.length / 2)].score : null;

const ceilingCount = sorted.filter((r) => r.score === 100).length;
const floorCount = sorted.filter((r) => r.score === 0).length;

const dir = indicatorDirection(m.id);
const cat = CATEGORIES[m.category];

function fmtRaw(v: number): string {
  return Number.isInteger(v) ? v.toLocaleString('en-US') : v.toLocaleString('en-US', { maximumFractionDigits: 2 });
}
let leaderProse = '';
if (rows.length > 0) {
  const ceilingProvinces = sorted.filter((r) => r.score === 100);
  const sortByRaw = (a: typeof sorted[0], b: typeof sorted[0]) =>
    dir === 'lower' ? a.raw - b.raw : b.raw - a.raw;
  const tiedTop = [...ceilingProvinces].sort(sortByRaw).slice(0, 3);
  const bottomRow = sorted[sorted.length - 1];
  const lastRow = sorted[0];

  if (ceilingCount === 0) {
    leaderProse = `${lastRow.name_th}เป็นจังหวัดที่ได้คะแนนสูงสุดในประเทศไทยสำหรับ${m.label_th} ด้วยค่า ${fmtRaw(lastRow.raw)} ${m.unit} คะแนน TLI ${lastRow.score}/100 ส่วนจังหวัดที่ได้คะแนนต่ำสุดคือ${bottomRow.name_th} (${fmtRaw(bottomRow.raw)} ${m.unit} คะแนน ${bottomRow.score}/100)`;
  } else if (ceilingCount === 1) {
    leaderProse = `${tiedTop[0].name_th}เป็นจังหวัดที่ได้คะแนนสูงสุดในประเทศไทยสำหรับ${m.label_th} ด้วยค่า ${fmtRaw(tiedTop[0].raw)} ${m.unit} คะแนน TLI สูงสุดที่ 100/100 ส่วนจังหวัดที่ได้คะแนนต่ำสุดคือ${bottomRow.name_th} (${fmtRaw(bottomRow.raw)} ${m.unit} คะแนน ${bottomRow.score}/100)`;
  } else {
    const names = tiedTop.map((r) => r.name_th);
    const list = names.length === 2 ? `${names[0]} และ ${names[1]}` : `${names[0]} ${names[1]} และ ${names[2]}`;
    leaderProse = `${ceilingCount} จังหวัดของไทยได้คะแนน TLI สูงสุดที่ 100/100 สำหรับ${m.label_th} จังหวัดที่ค่าดิบดีที่สุดคือ ${list} (ค่าดิบ ${fmtRaw(tiedTop[tiedTop.length - 1].raw)} ถึง ${fmtRaw(tiedTop[0].raw)} ${m.unit}) ส่วนจังหวัดที่ได้คะแนนต่ำสุดคือ${bottomRow.name_th} (${fmtRaw(bottomRow.raw)} ${m.unit} คะแนน ${bottomRow.score}/100)`;
  }
}
const description = `${m.label_th} แหล่งข้อมูล: ${m.source} ครอบคลุม ${rows.length} จาก 77 จังหวัดของไทย`;

const datasetSchema = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: m.label_th,
  alternateName: m.label_en,
  description: m.source_description ?? `${m.label_th} ตามที่เผยแพร่ใน Thailand Liveability Index`,
  url: `https://thailandliveabilityindex.com/th/indicators/${slug}/`,
  isPartOf: {
    '@type': 'Dataset',
    name: 'Thailand Liveability Index',
    url: 'https://thailandliveabilityindex.com/',
  },
  measurementTechnique: m.source_description ?? m.source,
  variableMeasured: {
    '@type': 'PropertyValue',
    name: m.label_th,
    unitText: m.unit,
  },
  spatialCoverage: {
    '@type': 'Place',
    name: 'Thailand (77 provinces)',
  },
  temporalCoverage: freshestAsOf || '2024',
  creator: {
    '@type': 'Person',
    name: 'William J. Reynolds',
    sameAs: 'https://orcid.org/0009-0005-1217-7465',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Thailand Liveability Index',
    url: 'https://thailandliveabilityindex.com/',
  },
  license: 'https://creativecommons.org/licenses/by-nc/4.0/',
  citation: m.source,
  isBasedOn: m.source_url,
  keywords: ['Thailand', 'liveability', 'province', cat.label_th, m.label_th],
};
---
<Site
  title={`${m.label_th} · TLI`}
  description={description}
  locale="th"
  canonicalPath={`/th/indicators/${slug}/`}
>
  <script type="application/ld+json" set:html={JSON.stringify(datasetSchema)} />

  <main class="container indicator-page">
    <Breadcrumbs locale="th" items={[
      { label: 'ตัวชี้วัด', href: '/th/indicators/' },
      { label: cat.label_th, href: `/th/indicators/#${m.category}`, chip: { icon: cat.icon, cssClass: cat.cssClass } },
      { label: m.label_th },
    ]} />

    <header class="indicator-page__head">
      <p class="tli-eyebrow">ตัวชี้วัด · TLI {m.id}</p>
      <h1>{m.label_th}</h1>
      <p class="indicator-page__th" lang="en">{m.label_en}</p>
      <div class="indicator-page__meta">
        {freshestAsOf ? (
          <ProvenanceChip variant="fresh" icon="calendar">
            {`ณ ${freshestAsOf}`}
          </ProvenanceChip>
        ) : (
          <ProvenanceChip variant="stale" icon="clock-alert">
            ณ — รอเติมข้อมูล
          </ProvenanceChip>
        )}
        <ProvenanceChip icon="book-open">{m.unit}</ProvenanceChip>
        <ProvenanceChip icon="badge-check">{`น้ำหนัก ${m.weight}`}</ProvenanceChip>
      </div>
    </header>

    <section class="indicator-page__source">
      <h2>แหล่งข้อมูล</h2>
      <p>
        <a href={m.source_url} target="_blank" rel="noopener noreferrer">
          {m.source}
          <Lucide name="external-link" size={14} class="tli-citations__icon" />
        </a>
      </p>
      {m.source_description && <p class="indicator-page__source-desc">{m.source_description}</p>}
    </section>

    {hasData && (
      <section class="indicator-page__leader" aria-labelledby="indicator-leader-h">
        <h2 id="indicator-leader-h">จังหวัดใดในประเทศไทยที่ได้คะแนนสูงสุดสำหรับ{m.label_th}?</h2>
        <p lang="th">{leaderProse}</p>
      </section>
    )}

    <section class="indicator-page__coverage">
      <h2>ความครอบคลุม</h2>
      <p>
        {hasData ? (
          <>{rows.length} จาก 77 จังหวัด ค่ามัธยฐาน: {median} คะแนนแต่ละจังหวัดถูก
          ปรับให้อยู่ในช่วง 0–100 ตามค่ามาตรฐานคงที่ คะแนนยิ่งสูงยิ่งดี</>
        ) : (
          <>การกระจายค่ารายจังหวัดของตัวชี้วัดนี้ยังไม่ได้ถูกบรรจุในชุดข้อมูลปัจจุบัน
          จะปรากฏที่นี่เมื่อรอบการประมวลผลถัดไปเสร็จสิ้น</>
        )}
      </p>
    </section>

    {hasData && (
      <section class="indicator-page__distribution">
        <div class="indicator-page__columns-explainer" role="note" lang="th">
          <p>
            <strong>วิธีอ่านคอลัมน์</strong>
            <span class="indicator-page__columns-row">
              <span class="indicator-page__columns-key">ค่าดิบ</span>
              <span class="indicator-page__columns-val">ค่าวัดจริงในหน่วย {m.unit}</span>
            </span>
            <span class="indicator-page__columns-row">
              <span class="indicator-page__columns-key">คะแนน</span>
              <span class="indicator-page__columns-val">
                ปรับให้อยู่ในช่วง 0–100 เทียบกับเกณฑ์มาตรฐานคงที่ (ไม่ใช่เปอร์เซ็นไทล์)
                {dir && <> <strong>{directionPhrase(dir, 'th')}</strong></>}
              </span>
            </span>
            {(ceilingCount > 1 || floorCount > 1) && (
              <span class="indicator-page__columns-row">
                <span class="indicator-page__columns-key">เหตุที่เสมอกัน</span>
                <span class="indicator-page__columns-val">
                  {ceilingCount > 1 && <>{ceilingCount} จังหวัดได้คะแนนเพดาน 100 เท่ากันเพราะค่าดิบสูงกว่าหรือเท่ากับเกณฑ์บน </>}
                  {floorCount > 1 && <>{floorCount} จังหวัดได้คะแนนพื้น 0 เท่ากันที่เกณฑ์ล่าง </>}
                  จังหวัดที่เกินเกณฑ์ไม่ถูกแยกแยะต่อ — เป็นการแลกเพื่อให้คะแนนเทียบกันได้ปีต่อปีแทนที่จะใช้เปอร์เซ็นไทล์
                </span>
              </span>
            )}
          </p>
        </div>

        <h2>จังหวัดคะแนนสูงสุด</h2>
        <table class="indicator-table">
          <thead>
            <tr>
              <th>อันดับ</th>
              <th>จังหวัด</th>
              <th title={`ค่าวัดจริงในหน่วย ${m.unit}`}>ค่าดิบ <span class="indicator-table__unit">({m.unit})</span></th>
              <th title="ปรับ 0–100 เทียบเกณฑ์มาตรฐานคงที่ ค่าสูงดีกว่า">คะแนน</th>
            </tr>
          </thead>
          <tbody>
            {top.map((row, i) => (
              <tr>
                <td>{i + 1}</td>
                <td><a href={`/th/${row.id}/`}>{row.name_th}</a></td>
                <td>{row.raw}</td>
                <td><strong>{row.score}</strong></td>
              </tr>
            ))}
          </tbody>
        </table>

        <h2>จังหวัดคะแนนต่ำสุด</h2>
        <table class="indicator-table">
          <thead>
            <tr>
              <th>อันดับ</th>
              <th>จังหวัด</th>
              <th title={`ค่าวัดจริงในหน่วย ${m.unit}`}>ค่าดิบ <span class="indicator-table__unit">({m.unit})</span></th>
              <th title="ปรับ 0–100 เทียบเกณฑ์มาตรฐานคงที่ ค่าสูงดีกว่า">คะแนน</th>
            </tr>
          </thead>
          <tbody>
            {bottom.map((row, i) => (
              <tr>
                <td>{rows.length - i}</td>
                <td><a href={`/th/${row.id}/`}>{row.name_th}</a></td>
                <td>{row.raw}</td>
                <td><strong>{row.score}</strong></td>
              </tr>
            ))}
          </tbody>
        </table>

        <details class="indicator-page__all">
          <summary>
            <span class="indicator-page__all-label">แสดงทั้ง {sorted.length} จังหวัด</span>
            <span class="indicator-page__all-hint">เรียงคะแนนจากสูงไปต่ำ</span>
          </summary>
          <table class="indicator-table indicator-page__all-table">
            <thead>
              <tr>
                <th>อันดับ</th>
                <th>จังหวัด</th>
                <th title={`ค่าวัดจริงในหน่วย ${m.unit}`}>ค่าดิบ <span class="indicator-table__unit">({m.unit})</span></th>
                <th title="ปรับ 0–100 เทียบเกณฑ์มาตรฐานคงที่ ค่าสูงดีกว่า">คะแนน</th>
              </tr>
            </thead>
            <tbody>
              {sorted.map((row, i) => (
                <tr>
                  <td>{i + 1}</td>
                  <td><a href={`/th/${row.id}/`}>{row.name_th}</a></td>
                  <td>{row.raw}</td>
                  <td><strong>{row.score}</strong></td>
                </tr>
              ))}
            </tbody>
          </table>
        </details>
      </section>
    )}

    <section class="indicator-page__methodology">
      <h2>ระเบียบวิธี</h2>
      <p>
        ดู <a href="/th/methodology/">หน้าระเบียบวิธี</a> สำหรับวิธีการให้คะแนน TLI
        ทั้งหมด รวมถึงวิธีการที่หมวด {cat.label_th} รวมเข้ากับอีก 6 หมวดผ่าน
        ค่าเฉลี่ยเรขาคณิต
      </p>
      <p class="indicator-page__cite">
        อ้างอิง: <em>"{m.label_th}" Thailand Liveability Index, 2026 CC BY-NC 4.0</em>
      </p>
    </section>

    {siblings.length > 0 && (
      <section class="indicator-page__siblings" aria-labelledby="siblings-h">
        <h2 id="siblings-h">ตัวชี้วัดอื่นในหมวด{cat.label_th}</h2>
        <ul class="indicator-page__siblings-list">
          {siblings.map((s) => (
            <li>
              <a href={`/th/indicators/${SLUG_MAP[s.id] ?? s.id}/`}>
                <span class="indicator-page__siblings-name">{s.label_th}</span>
                <span class="indicator-page__siblings-meta">
                  <span class="indicator-page__siblings-unit">{s.unit}</span>
                  <span class="indicator-page__siblings-source">{s.source}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
        <p class="indicator-page__siblings-more">
          <a href="/th/indicators/">ดูตัวชี้วัดทั้งหมด →</a>
        </p>
      </section>
    )}
  </main>
</Site>

<style>
  .indicator-page { max-width: 760px; padding-block: var(--sp-7); }
  .breadcrumb { display: flex; align-items: center; gap: var(--sp-2); font-size: var(--fs-13); margin-bottom: var(--sp-5); color: var(--ink-3); }
  .breadcrumb a { color: var(--ink-2); text-decoration: none; }
  .breadcrumb a:hover { color: var(--brand); }
  .breadcrumb__sep { color: var(--ink-3); }
  .indicator-page__head { margin-bottom: var(--sp-7); padding-bottom: var(--sp-5); border-bottom: 1px solid var(--rule); }
  .indicator-page__head h1 { line-height: var(--lh-tight); margin-bottom: var(--sp-2); }
  .indicator-page__th { color: var(--ink-2); font-size: var(--fs-15); margin-bottom: var(--sp-3); }
  .indicator-page__meta { display: flex; flex-wrap: wrap; gap: var(--sp-3); }
  .indicator-page__source, .indicator-page__coverage, .indicator-page__distribution, .indicator-page__methodology { margin-bottom: var(--sp-7); }
  .indicator-page__source-desc { color: var(--ink-2); font-size: var(--fs-15); margin-top: var(--sp-2); }
  .indicator-table { width: 100%; border-collapse: collapse; margin-bottom: var(--sp-5); }
  .indicator-table th, .indicator-table td { padding: var(--sp-2) var(--sp-3); text-align: left; border-bottom: 1px solid var(--rule); }
  .indicator-table th { font-weight: var(--fw-medium); font-size: var(--fs-13); color: var(--ink-3); }
  .indicator-table tbody a { color: var(--brand); text-decoration: none; }
  .indicator-table tbody a:hover { text-decoration: underline; }
  .indicator-page__cite { font-size: var(--fs-13); color: var(--ink-3); margin-top: var(--sp-4); padding-top: var(--sp-3); border-top: 1px dashed var(--rule); }
  .indicator-page__all { margin-top: var(--sp-6); border-top: 1px solid var(--rule); padding-top: var(--sp-4); }
  .indicator-page__all > summary { cursor: pointer; padding: var(--sp-3) 0; display: flex; flex-direction: column; gap: var(--sp-1); list-style: none; user-select: none; }
  .indicator-page__all > summary::-webkit-details-marker { display: none; }
  .indicator-page__all-label { font: var(--fw-semibold) var(--fs-14)/1 var(--font-sans); color: var(--brand); }
  .indicator-page__all-label::before { content: "▸ "; transition: transform var(--dur-2); display: inline-block; }
  .indicator-page__all[open] > summary .indicator-page__all-label::before { content: "▾ "; }
  .indicator-page__all-hint { font-size: var(--fs-12); color: var(--ink-3); }
  .indicator-page__all-table { margin-top: var(--sp-3); }

  .indicator-page__siblings { margin-top: var(--sp-7); padding-top: var(--sp-6); border-top: 1px solid var(--rule); }
  .indicator-page__siblings h2 { margin-bottom: var(--sp-4); font-size: var(--fs-18); }
  .indicator-page__siblings-list { list-style: none; padding: 0; margin: 0; display: grid; gap: var(--sp-2); grid-template-columns: 1fr; }
  @media (min-width: 600px) { .indicator-page__siblings-list { grid-template-columns: 1fr 1fr; } }
  .indicator-page__siblings-list a {
    display: flex; flex-direction: column; gap: 2px;
    padding: var(--sp-3) var(--sp-4);
    border: 1px solid var(--rule);
    border-radius: var(--r-2);
    background: var(--paper);
    color: var(--ink);
    text-decoration: none;
    transition: border-color 120ms ease, transform 120ms ease;
  }
  .indicator-page__siblings-list a:hover { border-color: var(--brand); transform: translateY(-1px); }
  .indicator-page__siblings-name { font-weight: var(--fw-medium); line-height: var(--lh-tight); }
  .indicator-page__siblings-meta { display: flex; gap: var(--sp-3); font-size: var(--fs-12); color: var(--ink-3); flex-wrap: wrap; }
  .indicator-page__siblings-more { margin-top: var(--sp-4); font-size: var(--fs-14); }
  .indicator-page__siblings-more a { color: var(--brand); text-decoration: none; }
  .indicator-page__siblings-more a:hover { text-decoration: underline; }

  .indicator-page__columns-explainer {
    padding: var(--sp-3) var(--sp-4);
    margin-bottom: var(--sp-5);
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-radius: var(--r-2);
    font-size: var(--fs-13);
    line-height: var(--lh-base);
    color: var(--ink-2);
  }
  .indicator-page__columns-explainer p { margin: 0; }
  .indicator-page__columns-explainer strong { color: var(--ink); }
  .indicator-page__columns-row {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: var(--sp-3);
    margin-top: var(--sp-2);
    align-items: start;
  }
  .indicator-page__columns-key {
    font: var(--fw-semibold) var(--fs-12)/1.2 var(--font-sans);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--ink-3);
  }
  @media (max-width: 600px) {
    .indicator-page__columns-row { grid-template-columns: 1fr; gap: 2px; }
  }
  .indicator-table__unit {
    display: inline-block;
    margin-left: 4px;
    font-weight: var(--fw-regular);
    color: var(--ink-3);
    font-size: var(--fs-12);
    text-transform: none;
    letter-spacing: 0;
  }

  .indicator-page__leader {
    margin-bottom: var(--sp-7);
    padding: var(--sp-4) var(--sp-5);
    background: var(--brand-tint);
    border-left: 3px solid var(--brand);
    border-radius: var(--r-2);
  }
  .indicator-page__leader h2 {
    margin: 0 0 var(--sp-2) 0;
    font-size: var(--fs-18);
    line-height: var(--lh-tight);
    color: var(--ink);
  }
  .indicator-page__leader p { margin: 0; color: var(--ink-2); line-height: var(--lh-base); }
</style>
