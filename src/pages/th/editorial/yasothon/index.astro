---
// Copyright (c) 2026 Will Reynolds
// SPDX-License-Identifier: MIT
import Site from '../../../../layouts/Site.astro';
import ProvenanceChip from '../../../../components/ProvenanceChip.astro';
import ScorePrimitive from '../../../../components/ScorePrimitive.astro';
import Lucide from '../../../../components/Lucide.astro';
import scoresData from '../../../../data/scores.json';
import type { ScoresFile } from '../../../../data/types';
import { CATEGORIES, CATEGORY_ORDER, regionLabel } from '../../../../data/lookups';

const data = scoresData as ScoresFile;
const province = data.provinces.find((p) => p.id === 'yasothon');

if (!province) {
  throw new Error('Yasothon not found in scores.json. Cannot render editorial.');
}

const region = regionLabel(province.region, 'th');
const cats = CATEGORY_ORDER.map((id) => ({
  id,
  meta: CATEGORIES[id],
  score: province.categories[id].score,
  indicatorCount: province.categories[id].indicator_count,
}));

const strongest = [...cats].sort((a, b) => b.score - a.score)[0];
const weakest = [...cats].sort((a, b) => a.score - b.score)[0];
---
<Site
  title="ยโสธร เมื่อมองจากข้อมูลและจากการลงพื้นที่ · ดัชนีคุณภาพการอยู่อาศัย"
  description={`บทบรรณาธิการ Layer 2 — ยโสธร คะแนนรวม TLI ${province.composite} อันดับ ${province.rank} จาก 77`}
  locale="th"
  canonicalPath="/th/editorial/yasothon/"
  ogImage="/og/yasothon.png"
>
  <article class="editorial" lang="th">
    <header class="editorial__head">
      <p class="tli-eyebrow">บทบรรณาธิการ Layer 2 · บันทึกภาคสนามจังหวัด</p>
      <h1 class="editorial__title">ยโสธร เมื่อมองจากข้อมูลและจากการลงพื้นที่</h1>
      <p class="editorial__byline">
        โดย <strong>Will Reynolds</strong> · <time datetime="2026-05-10">10 พฤษภาคม 2026</time>
      </p>
      <p class="editorial__lede">
        ยโสธรอยู่อันดับ <strong>{province.rank} จาก 77</strong> ของคะแนนรวม TLI —
        คะแนน <span class="tli-num">{province.composite}</span> จาก 100 ตัวเลขนี้อยู่ในกลุ่มหนึ่งในสามล่างของการกระจายตัว
        แต่หมวดที่อยู่เบื้องล่างเล่าเรื่องที่น่าสนใจกว่าตัวเลขหัวเรื่อง นี่คือสิ่งที่สามวันในพื้นที่
        เปลี่ยนและไม่เปลี่ยนเกี่ยวกับวิธีที่ผมอ่านข้อมูล
      </p>
      <div class="editorial__meta">
        <ProvenanceChip variant="fresh" icon="calendar" lang="th">ลงพื้นที่ 8–10 พฤษภาคม 2026</ProvenanceChip>
        <ProvenanceChip icon="badge-check" lang="th">บทบรรณาธิการ · ไม่นำเข้าระบบคะแนน</ProvenanceChip>
      </div>
    </header>

    <div class="editorial__body">
      <div class="editorial__prose">
        <section class="editorial__section">
          <p class="editorial__draft-note">
            <strong>นี่คือเทมเพลต</strong> — เนื้อหาเป็นโครงสร้างของบันทึกภาคสนาม
            สำหรับเขียนใหม่หลังการลงพื้นที่เดือนพฤษภาคม
          </p>

          <p class="editorial__lead-para">
            <span class="editorial__dropcap">ย</span>โสธรเป็นจังหวัดเล็กในภาคอีสาน
            มีประชากรไม่ถึง 530,000 คน คะแนนรวม TLI ที่ <span class="tli-num">{province.composite}</span>
            อยู่ในกลุ่มหนึ่งในสามล่าง ตัวเลขนี้ทำหน้าที่ของมัน — เป็นค่าเฉลี่ยเรขาคณิตของอินพุตอิสระ 7 ตัว
            ซึ่งสองตัวอ่อนพอที่จะดึงคะแนนรวมลงแม้ว่าหมวดอื่นจะน่าเชื่อถือ การเดินผ่านตลาดและย่านงานบุญบั้งไฟ
            ไม่เปลี่ยนสิ่งที่คณิตศาสตร์บอก แต่เปลี่ยนความรู้สึกที่คณิตศาสตร์มอบให้
            และสิ่งที่คณิตศาสตร์ไม่ได้จับ
          </p>

          <p>
            สัญญาณที่แข็งแกร่งที่สุดในข้อมูลคือ<em>ความปลอดภัย</em> ยโสธรได้
            <span class="tli-num">{strongest.score}</span> ใน <em>{strongest.meta.label_th}</em>
            — มาจากอัตราการเสียชีวิต ACLED ที่ใกล้ศูนย์ และจำนวนเหตุการณ์ต่อหัวประชากรที่ต่ำในกรอบ 5 ปี
          </p>
        </section>

        <h2 class="editorial__h2">หมวดที่อ่อนที่สุดวัดอะไรจริง ๆ</h2>
        <section class="editorial__section">
          <p>
            สัญญาณที่อ่อนที่สุดคือ <em>{weakest.meta.label_th}</em> ที่ <span class="tli-num">{weakest.score}</span>
            <em>[ย่อหน้าบันทึกภาคสนาม: หมวดที่อ่อนนี้ดูอย่างไรในพื้นที่จริง]</em>
          </p>
        </section>

        <h2 class="editorial__h2">ที่ที่คะแนนถูกต้อง และที่ที่มันละเลย</h2>
        <section class="editorial__section">
          <p>
            <em>[ย่อหน้าบันทึกภาคสนาม: ที่ข้อมูลและสถานที่สอดคล้องกัน
            ที่ข้อมูลละเลยพื้นผิวจริง ที่กรอบตัวชี้วัดยังไม่ละเอียดพอ]</em>
          </p>
          <figure class="editorial__figure">
            <div class="editorial__photo-placeholder">
              <span>ภาพถ่าย · แสงธรรมชาติ · เชิงสารคดี</span>
              <span class="editorial__photo-meta">คำอธิบาย + วันที่ · CC BY 4.0</span>
            </div>
            <figcaption>ภาพถ่ายภาคสนาม 8–10 พฤษภาคม 2026</figcaption>
          </figure>
        </section>

        <h2 class="editorial__h2">ระเบียบวิธีมีข้อจำกัดที่ทราบในที่นี้</h2>
        <section class="editorial__section">
          <p>
            <em>[ย่อหน้าบันทึกภาคสนาม: ข้อจำกัดที่ TLI v1.0 แสดงให้เห็นชัดที่สุดในยโสธร]</em>
          </p>
        </section>

        <h2 class="editorial__h2">สิ่งที่ผู้อ่านควรนำกลับไป</h2>
        <section class="editorial__section">
          <p>
            <em>[ย่อหน้าปิด: สังเคราะห์ คะแนนรวมถูกต้องในคณิตศาสตร์ของมัน
            ไม่ปิดบังว่ามันวัดอะไร สถานที่มีพื้นผิวที่ดัชนีเจ็ดหมวดไม่มีวันจับได้ทั้งหมด]</em>
          </p>
        </section>

        <footer class="editorial__refs">
          <p class="editorial__refs-note">
            <Lucide name="badge-check" size={12} class="tli-citations__icon" />
            บทบรรณาธิการนี้อยู่<strong>ข้าง ๆ</strong> คะแนนเชิงอัลกอริทึม ไม่ใช่ทับ
            คะแนนรวม คะแนนตามหมวด และตัวชี้วัดปรากฏใน UI ของตัวเองที่
            <a href={`/th/${province.id}/`} class="editorial__link">หน้าจังหวัด</a>
            กรอบบรรณาธิการใด ๆ ในที่นี้ไม่ป้อนกลับเข้าระบบคะแนน
          </p>
        </footer>
      </div>

      <aside class="editorial__sidebar" aria-label="คะแนนเชิงอัลกอริทึม">
        <div class="editorial__sidebar-inner">
          <p class="tli-eyebrow editorial__sidebar-eyebrow" lang="th">คะแนนเชิงอัลกอริทึม</p>
          <h2 class="editorial__sidebar-title" lang="th">{province.name_th}</h2>
          <p class="editorial__sidebar-meta" lang="th">
            {province.name_en} · {region} · ประชากร {province.population.toLocaleString('en-US')}
          </p>

          <div class="editorial__sidebar-composite">
            <ScorePrimitive
              score={province.composite ?? 0}
              scale="hero"
              floored={province.floored}
              locale="th"
            />
            <p class="editorial__sidebar-rank" lang="th">
              อันดับ <strong>{province.rank}</strong> จาก 77
            </p>
          </div>

          <h3 class="editorial__sidebar-h3" lang="th">ตามหมวดหมู่</h3>
          <ul class="editorial__sidebar-cats">
            {cats.map((c) => (
              <li class="editorial__sidebar-cat">
                <span class="editorial__sidebar-cat-row">
                  <span class:list={['tli-cat-dot', c.meta.cssClass]} aria-hidden="true"></span>
                  <span class="editorial__sidebar-cat-label" lang="th">{c.meta.label_th}</span>
                  <span class="editorial__sidebar-cat-score tli-num">{c.score}</span>
                </span>
                <span class="editorial__sidebar-cat-meta" lang="th">
                  {c.indicatorCount} ตัวชี้วัด
                </span>
              </li>
            ))}
          </ul>

          <a href={`/th/${province.id}/`} class="editorial__sidebar-link" lang="th">
            หน้าจังหวัดเต็ม
            <Lucide name="external-link" size={11} class="tli-link__icon" />
          </a>
        </div>
      </aside>
    </div>
  </article>
</Site>
