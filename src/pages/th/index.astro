import Site from '../../layouts/Site.astro';
import HomeHero from '../../components/HomeHero.astro';
import TliMap from '../../components/TliMap.astro';
import CuratedRow from '../../components/CuratedRow.astro';
import Controls from '../../components/Controls.astro';
import ProvinceGrid from '../../components/ProvinceGrid.astro';
import ProvenanceChip from '../../components/ProvenanceChip.astro';
import Lucide from '../../components/Lucide.astro';
import scoresData from '../../data/scores.json';
import type { ScoresFile } from '../../data/types';
import { CHROME } from '../../data/lookups';

const data = scoresData as ScoresFile;
const provinces = data.provinces;
const C = CHROME.th;

const asOfDates = provinces.flatMap((p) =>
  Object.values(p.categories).map((c) => c.freshest_as_of),
);
const latestAsOf = asOfDates.sort().at(-1) ?? data.generated_at.slice(0, 10);
const asOfDisplay = new Date(latestAsOf).toLocaleDateString('en-US', {
  month: 'short',
  year: 'numeric',
}).toUpperCase();

const sourceSet = new Set<string>();
provinces.forEach((p) =>
  Object.values(p.categories).forEach((c) =>
    c.indicators.forEach((i) => sourceSet.add(i.source)),
  ),
);
const allSources = Array.from(sourceSet);
const sourceTotal = allSources.length;
const sourcesShown = allSources.slice(0, 5).join(' · ');
const sourcesExtra = sourceTotal > 5 ? sourceTotal - 5 : 0;
const sources = sourcesExtra > 0
  ? `${sourcesShown} · และอีก ${sourcesExtra}`
  : sourcesShown;

const homeDatasetSchema = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: 'Thailand Liveability Index',
  alternateName: 'ดัชนีคุณภาพการอยู่อาศัยของประเทศไทย',
  description: C.homeDescription,
  url: 'https://thailandliveabilityindex.com/th/',
  identifier: 'https://thailandliveabilityindex.com/',
  spatialCoverage: { '@type': 'Country', name: 'Thailand', alternateName: 'ประเทศไทย' },
  temporalCoverage: latestAsOf,
  variableMeasured: [
    'composite liveability score', 'environment & climate score', 'healthcare score',
    'connectivity & transport score', 'cost & economy score', 'safety & governance score',
    'lifestyle & culture score', 'demographics & scale score',
  ].map((name) => ({ '@type': 'PropertyValue', name })),
  creator: { '@type': 'Person', name: 'William J. Reynolds', sameAs: 'https://orcid.org/0009-0005-1217-7465' },
  publisher: { '@type': 'Organization', name: 'Thailand Liveability Index', url: 'https://thailandliveabilityindex.com/' },
  license: 'https://creativecommons.org/licenses/by-nc/4.0/',
  isAccessibleForFree: true,
  keywords: [
    'Thailand', 'liveability', 'จังหวัด', 'ดัชนีคุณภาพการอยู่อาศัย',
    '77 จังหวัด', 'ประเทศไทย', 'อันดับจังหวัด', 'คะแนนรวมจังหวัด',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Thailand Liveability Index',
  url: 'https://thailandliveabilityindex.com/',
  inLanguage: ['en', 'th'],
  publisher: { '@type': 'Organization', name: 'Thailand Liveability Index', url: 'https://thailandliveabilityindex.com/' },
};
---
<Site
  title={C.homeTitle}
  description={C.homeDescription}
  locale="th"
  canonicalPath="/th/"
  ogImage="/og/home.png"
>
  <script type="application/ld+json" set:html={JSON.stringify(homeDatasetSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <HomeHero locale="th" asOf={asOfDisplay} />

  <section class="home-section" aria-labelledby="map-section-title">
    <header class="home-section__head">
      <div>
        <h2 class="home-section__title" id="map-section-title" lang="th">{C.thailandAtAGlance}</h2>
        <p class="home-section__sub" lang="th">{C.thailandAtAGlanceSub}</p>
      </div>
      <ProvenanceChip icon="badge-check" lang="th">
        แผนที่ · 77 จังหวัด
      </ProvenanceChip>
    </header>
    <TliMap provinces={provinces} locale="th" />
    <div class="home-citations">
      {sources && <span>SOURCE · {sources.toUpperCase()}</span>}
      <span lang="th">{C.asOf} · {asOfDisplay}</span>
      <a href="/th/methodology/" class="home-citations__link" lang="th">
        <Lucide name="book-open" size={12} class="tli-citations__icon" />
        ระเบียบวิธี →
      </a>
    </div>
  </section>

  <section class="home-section" aria-labelledby="curated-section-title">
    <header class="home-section__head">
      <div>
        <h2 class="home-section__title" id="curated-section-title" lang="th">{C.curatedTitle}</h2>
        <p class="home-section__sub" lang="th">{C.curatedSub}</p>
      </div>
      <ProvenanceChip icon="badge-check" lang="th">{C.curatedTag}</ProvenanceChip>
    </header>
    <CuratedRow provinces={provinces} locale="th" />
  </section>

  <section class="home-section" aria-labelledby="all77-section-title">
    <header class="home-section__head">
      <div>
        <h2 class="home-section__title" id="all77-section-title" lang="th">{C.all77Title}</h2>
        <p class="home-section__sub" lang="th">{C.all77Sub}</p>
      </div>
    </header>
    <Controls locale="th" total={provinces.length} />
    <ProvinceGrid provinces={provinces} locale="th" />
    <div class="home-citations">
      <span lang="th">{C.citationsCompositeMethod}</span>
      <span lang="th">{C.citationsScale}</span>
      <a href="/th/methodology/#composite" class="home-citations__link" lang="th">
        <Lucide name="book-open" size={12} class="tli-citations__icon" />
        {C.howCompositeBuilt}
      </a>
    </div>
  </section>
</Site>
