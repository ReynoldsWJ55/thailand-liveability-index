import Site from '../../../layouts/Site.astro';
import ProvenanceChip from '../../../components/ProvenanceChip.astro';
import Lucide from '../../../components/Lucide.astro';
import scoresData from '../../../data/scores.json';
import type { ScoresFile, Indicator, CategoryId } from '../../../data/types';
import { CATEGORIES, CATEGORY_ORDER } from '../../../data/lookups';

const data = scoresData as ScoresFile;

interface SourceAggregate {
  source: string;
  source_url: string;
  source_description: string;
  indicator_ids: Set<string>;
  categories: Set<CategoryId>;
  freshest_as_of: string;
  oldest_as_of: string;
  province_count: number;
  has_stale: boolean;
  has_inherited: boolean;
}

const sources = new Map<string, SourceAggregate>();
for (const province of data.provinces) {
  for (const cat of Object.values(province.categories)) {
    for (const ind of cat.indicators as Indicator[]) {
      let agg = sources.get(ind.source);
      if (!agg) {
        agg = {
          source: ind.source,
          source_url: ind.source_url,
          source_description: ind.source_description ?? '',
          indicator_ids: new Set(),
          categories: new Set(),
          freshest_as_of: ind.as_of,
          oldest_as_of: ind.as_of,
          province_count: 0,
          has_stale: false,
          has_inherited: false,
        };
        sources.set(ind.source, agg);
      }
      agg.indicator_ids.add(ind.id);
      agg.categories.add(cat.id);
      if (ind.as_of > agg.freshest_as_of) agg.freshest_as_of = ind.as_of;
      if (ind.as_of < agg.oldest_as_of) agg.oldest_as_of = ind.as_of;
      agg.province_count += 1;
      if (ind.quality_flag === 'stale') agg.has_stale = true;
      if (ind.quality_flag === 'inherited') agg.has_inherited = true;
    }
  }
}
const sourceList = Array.from(sources.values()).sort((a, b) => a.source.localeCompare(b.source));
const indicatorCount = new Set(
  data.provinces.flatMap((p) =>
    Object.values(p.categories).flatMap((c) => c.indicators.map((i) => i.id)),
  ),
).size;

const categoryIndicators = CATEGORY_ORDER.map((cid) => {
  const ids = new Set<string>();
  const labels = new Map<string, string>();
  for (const province of data.provinces) {
    const c = province.categories[cid];
    if (!c) continue;
    for (const ind of c.indicators) {
      ids.add(ind.id);
      labels.set(ind.id, ind.label_th);
    }
  }
  return { id: cid, indicators: Array.from(ids), labels };
});
---
<Site
  title="เกี่ยวกับ · ดัชนีคุณภาพการอยู่อาศัยของประเทศไทย"
  description="แหล่งข้อมูลที่ใช้ในการคำนวณ TLI"
  locale="th"
  canonicalPath="/th/about/"
  ogImage="/og/about.png"
>
  <article class="methodology" lang="th">
    <header class="methodology__head">
      <p class="tli-eyebrow">เกี่ยวกับ · แหล่งที่มา</p>
      <h1 class="methodology__title">ข้อมูลเบื้องหลัง TLI</h1>
      <p class="methodology__lede">
        ตัวชี้วัดทุกตัวบนเว็บไซต์นี้มาจากข้อมูลเปิดของหน่วยงานรัฐไทย ข้อมูลทางวิทยาศาสตร์เปิด
        หรือผลการวิจัยที่มีลิขสิทธิ์เปิด หน้านี้แสดงรายการทุกแหล่ง ตัวชี้วัดที่เราใช้
        และวันที่ของข้อมูลล่าสุดที่อยู่ในชุดข้อมูลปัจจุบัน
      </p>
      <div class="methodology__meta">
        <ProvenanceChip variant="fresh" icon="calendar" lang="th">
          BUILD {data.generated_at.slice(0, 10).toUpperCase()}
        </ProvenanceChip>
        <ProvenanceChip icon="badge-check" lang="th">ระเบียบวิธี {data.methodology_version.toUpperCase()}</ProvenanceChip>
        <ProvenanceChip icon="book-open" lang="th">CC BY-NC 4.0</ProvenanceChip>
      </div>
    </header>

    <section class="methodology__section" id="overview">
      <h2 class="methodology__h2">ภาพรวม</h2>
      <ul class="about-stats">
        <li>
          <span class="about-stats__num tli-num">{data.provinces.length}</span>
          <span class="about-stats__label">จังหวัดในชุดข้อมูลนี้</span>
        </li>
        <li>
          <span class="about-stats__num tli-num">{indicatorCount}</span>
          <span class="about-stats__label">ตัวชี้วัดเฉพาะ</span>
        </li>
        <li>
          <span class="about-stats__num tli-num">{sourceList.length}</span>
          <span class="about-stats__label">แหล่งข้อมูลหลัก</span>
        </li>
        <li>
          <span class="about-stats__num tli-num">7</span>
          <span class="about-stats__label">หมวด</span>
        </li>
      </ul>
    </section>

    <section class="methodology__section" id="sources">
      <h2 class="methodology__h2">แหล่งข้อมูลหลัก</h2>
      <p>
        แต่ละแถวระบุแหล่งข้อมูล หมวดของ TLI ที่ใช้ ตัวชี้วัดที่ได้มา และความสดของข้อมูล
        คลิกเพื่อดูแหล่งต้นฉบับ
      </p>
      <ul class="about-sources">
        {sourceList.map((s) => (
          <li class="about-source">
            <div class="about-source__head">
              <a href={s.source_url} target="_blank" rel="noopener noreferrer" class="about-source__name">
                {s.source}
                <Lucide name="external-link" size={12} class="tli-citations__icon" />
              </a>
              {s.source_description && <p class="about-source__desc">{s.source_description}</p>}
              <div class="about-source__chips">
                <ProvenanceChip variant={s.has_stale ? 'stale' : 'fresh'} icon="calendar" lang="th">
                  {`ณ ${s.freshest_as_of}`}
                </ProvenanceChip>
                {s.has_stale && <ProvenanceChip variant="stale" icon="clock-alert" lang="th">ตัวชี้วัดเก่า</ProvenanceChip>}
              </div>
            </div>
            <dl class="about-source__meta">
              <div>
                <dt>หมวดที่ใช้</dt>
                <dd>
                  {Array.from(s.categories).map((cid, i) => (
                    <>
                      {i > 0 && ' · '}
                      <span class="about-source__cat">
                        <span class:list={['tli-cat-dot', CATEGORIES[cid].cssClass]} aria-hidden="true"></span>
                        {CATEGORIES[cid].label_th}
                      </span>
                    </>
                  ))}
                </dd>
              </div>
              <div>
                <dt>ตัวชี้วัด</dt>
                <dd class="tli-num">{s.indicator_ids.size}</dd>
              </div>
              <div>
                <dt>ความครอบคลุม</dt>
                <dd class="tli-num">{s.province_count} แถว</dd>
              </div>
            </dl>
          </li>
        ))}
      </ul>
    </section>

    <section class="methodology__section" id="categories">
      <h2 class="methodology__h2">หมวดและตัวชี้วัดในชุดข้อมูลนี้</h2>
      <p>
        เจ็ดหมวดของ TLI และตัวชี้วัดที่เชื่อมต่อแล้ว กรอบตัวชี้วัดเต็มมีประมาณ 22 ตัว
        บางตัวยังอยู่ระหว่างการพัฒนา
      </p>
      <ul class="about-categories">
        {categoryIndicators.map((entry) => {
          const cat = CATEGORIES[entry.id];
          return (
            <li class="about-category">
              <h3 class="about-category__name">
                <span class:list={['tli-cat-dot', cat.cssClass]} aria-hidden="true"></span>
                {cat.label_th}
              </h3>
              <ul class="about-category__indicators">
                {entry.indicators.map((id) => (
                  <li>
                    <span class="about-category__indicator-id tli-num">{id}</span>
                    <span class="about-category__indicator-label">{entry.labels.get(id)}</span>
                  </li>
                ))}
              </ul>
            </li>
          );
        })}
      </ul>
    </section>

    <section class="methodology__section" id="licensing">
      <h2 class="methodology__h2">สัญญาอนุญาต</h2>
      <p>
        <strong>ระเบียบวิธี รายการตัวชี้วัด และโครงสร้างหมวดหมู่</strong> ของ TLI เผยแพร่ภายใต้
        <a href="https://creativecommons.org/licenses/by-nc/4.0/deed.th" target="_blank" rel="noopener noreferrer">CC BY-NC 4.0</a>
        คุณสามารถคัดลอก ดัดแปลง เผยแพร่ต่อ และต่อยอด สำหรับการใช้งานที่ไม่ใช่เชิงพาณิชย์ —
        งานวิจัยทางวิชาการ งานข่าว การใช้ส่วนบุคคล การใช้เพื่อสาธารณประโยชน์และการศึกษา
        และการใช้โดยหน่วยงานราชการไทย — โดยให้เครดิต "Thailand Liveability Index, Reynolds 2026"
      </p>
      <p>
        <strong>การใช้เชิงพาณิชย์</strong> ถูกสงวนสิทธิ์และไม่ได้เปิดให้ใช้ในขณะนี้ ดู
        <a href="/th/licensing/">/th/licensing/</a> สำหรับประกาศการสงวนสิทธิ์ทั้งหมด
        ข้อความแสดงความสนใจในเชิงข้อมูลสามารถส่งได้ที่
        <a href="mailto:licensing@thailandliveabilityindex.com">licensing@thailandliveabilityindex.com</a>
        ข้อความเหล่านี้ถูกบันทึกเพื่อให้ผู้ดำเนินการรับทราบเท่านั้น และไม่ใช่ธุรกรรมเชิงพาณิชย์
      </p>
      <p>
        <strong>โค้ดส่วนหน้าเว็บ</strong> เผยแพร่ภายใต้
        <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener noreferrer">MIT License</a>
        <strong>ชุดข้อมูลดิบต้นทาง</strong> เป็นทรัพย์สินของผู้เผยแพร่ต้นฉบับและมีสัญญาอนุญาตของตนเอง
      </p>
    </section>

    <section class="methodology__section" id="cite">
      <h2 class="methodology__h2">วิธีการอ้างอิง</h2>
      <pre class="methodology__formula">
Reynolds, W. (2026). Thailand Liveability Index (Version {data.methodology_version}) [Data set].
https://thailandliveabilityindex.com</pre>
    </section>
  </article>
</Site>
