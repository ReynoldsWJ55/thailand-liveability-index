---
/**
 * Citation row — sits directly under any chart or table. Per design system,
 * never collapses to a tooltip. Fields:
 *   sources       — list of source names ("OpenAQ v3", "Open-Meteo", etc.)
 *   asOf          — ISO date the table reflects (oldest as_of, by convention)
 *   methodology   — anchor URL for "methodology →"
 *
 * For PR 3, methodology link points at /<locale>/methodology/ which doesn't
 * exist yet; renders as a plain anchor. Visible-but-inert is honest — better
 * than fabricating a working link.
 */
import Lucide from './Lucide.astro';
import { CHROME } from '../data/lookups';
import type { Locale } from '../data/types';

interface Props {
  sources: string[];
  asOf: string;
  methodologyHref?: string;
  locale: Locale;
  /** Anchor on the methodology page, e.g. "#climate". */
  methodologyAnchor?: string;
}
const {
  sources,
  asOf,
  methodologyHref,
  locale,
  methodologyAnchor = '',
} = Astro.props;
const C = CHROME[locale];
const sourceList = sources.join(' · ').toUpperCase();
const href = methodologyHref ?? `/${locale}/methodology/${methodologyAnchor}`;
---
<div class="tli-citations" style="padding-left: var(--sp-5); padding-right: var(--sp-5);">
  <span>{C.source.toUpperCase()} · {sourceList}</span>
  <span>
    <Lucide name="calendar" size={12} class="tli-citations__icon" />
    {C.asOf} {asOf}
  </span>
  <a href={href}>
    <Lucide name="book-open" size={12} class="tli-citations__icon" />
    {C.methodology.toUpperCase()} →
  </a>
</div>
