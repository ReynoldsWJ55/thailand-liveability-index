/**
 * Category card — one of seven per province. Composes the kit's `.cat-card`
 * class with the design-system band class. The card is itself an anchor link
 * to the indicator-detail section below; anchor scrolling needs no JS.
 */
import { bandClass, bandLabel } from '../lib/score-band';
import { CATEGORIES, CATEGORY_ANCHOR, categoryLabel, CHROME } from '../data/lookups';
import type { CategoryScore, Locale } from '../data/types';
import Lucide from './Lucide.astro';

interface Props {
  category: CategoryScore;
  locale: Locale;
  /** When true, this category is the floor reason — visually flagged. */
  isFloor?: boolean;
}
const { category, locale, isFloor = false } = Astro.props;
const meta = CATEGORIES[category.id];
const label = categoryLabel(category.id, locale);
const C = CHROME[locale];

const score = isFloor ? 0 : category.score;
const cls = ['cat-card', bandClass(score, isFloor), isFloor ? 'cat-card--floored' : '']
  .filter(Boolean)
  .join(' ');
const bandWord = bandLabel(score, isFloor, locale);
---
<a href={`#${CATEGORY_ANCHOR[category.id]}`} class={cls}>
  <span class="cat-card__head">
    <Lucide name={meta.icon} size={16} class="cat-card__icon" />
    <span {...locale === 'th' ? { lang: 'th' } : {}}>{label}</span>
  </span>
  <span class="cat-card__num">{score}</span>
  <span class="cat-card__band" {...locale === 'th' ? { lang: 'th' } : {}}>
    {bandWord}
  </span>
  <span class="cat-card__meta">
    {C.indicatorCount(category.indicator_count)}
  </span>
</a>
