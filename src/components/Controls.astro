---
/**
 * Filter / sort controls above the grid. Vanilla JS island.
 *
 * Behavior:
 *   - Region (segmented pill group, mutually exclusive)
 *   - Coverage (segmented pill group)
 *   - Category leader (toggleable individual pills, "Any" deselects all)
 *   - Sort (segmented pill group)
 *   - "Showing N of <total>" counter at the right of the sort row
 *
 * Filtering is DOM-only: tiles in ProvinceGrid have data-* attrs, this script
 * adds/removes 'is-hidden' on each based on combined filter state. Sort
 * re-orders by mutating the parent's flex/grid order CSS property — no
 * DOM tree mutation, fast and stable.
 *
 * The Top-5 eyebrow is hidden when sort != composite-desc; the floored row
 * stays put (it's about the data, not the sort).
 */
import { CATEGORIES, CATEGORY_ORDER, CHROME } from '../data/lookups';
import type { Locale, Region } from '../data/types';

interface Props {
  locale: Locale;
  total: number;
}
const { locale, total } = Astro.props;
const C = CHROME[locale];

const regions: { id: 'all' | Region; label: string }[] = [
  { id: 'all', label: C.filterAll },
  { id: 'Bangkok and Vicinities', label: locale === 'th' ? 'กรุงเทพฯ' : 'Bangkok' },
  { id: 'Central', label: locale === 'th' ? 'กลาง' : 'Central' },
  { id: 'Eastern', label: locale === 'th' ? 'ตะวันออก' : 'East' },
  { id: 'Western', label: locale === 'th' ? 'ตะวันตก' : 'West' },
  { id: 'Northern', label: locale === 'th' ? 'เหนือ' : 'North' },
  { id: 'Northeastern', label: locale === 'th' ? 'อีสาน' : 'Northeast' },
  { id: 'Southern', label: locale === 'th' ? 'ใต้' : 'South' },
];

const tiers = [
  { id: 'all', label: C.filterAll },
  { id: '1', label: C.tier1Full },
  { id: '2', label: C.tier2Partial },
];

const sorts = [
  { id: 'composite-desc', label: C.sortCompositeDesc },
  { id: 'composite-asc', label: C.sortCompositeAsc },
  { id: 'name', label: C.sortName },
];
---
<div class="tli-controls" data-component="controls" data-total={total}>
  <div class="tli-controls__row">
    <span class="tli-controls__label">{C.filterRegion}</span>
    <div class="tli-pill-group" role="group" aria-label={C.filterRegion} data-filter="region">
      {regions.map((r) => (
        <button type="button" data-value={r.id} aria-pressed={r.id === 'all' ? 'true' : 'false'}>
          {r.label}
        </button>
      ))}
    </div>

    <span class="tli-controls__divider" aria-hidden="true"></span>

    <span class="tli-controls__label">{C.filterCoverage}</span>
    <div class="tli-pill-group" role="group" aria-label={C.filterCoverage} data-filter="tier">
      {tiers.map((t) => (
        <button type="button" data-value={t.id} aria-pressed={t.id === 'all' ? 'true' : 'false'}>
          {t.label}
        </button>
      ))}
    </div>
  </div>

  <div class="tli-controls__row">
    <span class="tli-controls__label">{C.filterCategory}</span>
    <div class="tli-cat-pills" role="group" aria-label={C.filterCategory} data-filter="leader">
      <button type="button" class="tli-cat-pill" data-value="any" aria-pressed="true">{C.filterAny}</button>
      {CATEGORY_ORDER.map((id) => {
        const cat = CATEGORIES[id];
        return (
          <button type="button" class="tli-cat-pill" data-value={id} aria-pressed="false">
            <span class:list={['tli-cat-dot', cat.cssClass]} aria-hidden="true"></span>
            {locale === 'th' ? cat.label_th : cat.label_en}
          </button>
        );
      })}
    </div>
  </div>

  <div class="tli-controls__row">
    <span class="tli-controls__label">{C.filterSort}</span>
    <div class="tli-pill-group" role="group" aria-label={C.filterSort} data-filter="sort">
      {sorts.map((s) => (
        <button type="button" data-value={s.id} aria-pressed={s.id === 'composite-desc' ? 'true' : 'false'}>
          {s.label}
        </button>
      ))}
    </div>
    <span class="tli-controls__count tli-num" data-count>
      <span data-shown>{total}</span> / {total}
    </span>
  </div>
</div>

<script>
  // Vanilla filter / sort. Runs once per page load.
  document.querySelectorAll<HTMLElement>('[data-component="controls"]').forEach((root) => {
    const grid = document.querySelector<HTMLElement>('[data-component="province-grid"]');
    if (!grid) return;

    const tiles = Array.from(grid.querySelectorAll<HTMLElement>('[data-tile]'));
    const eyebrow = grid.querySelector<HTMLElement>('[data-top-eyebrow]');
    const showCounter = root.querySelector<HTMLElement>('[data-shown]');

    type State = {
      region: string;
      tier: string;
      leader: string;
      sort: string;
    };
    const state: State = {
      region: 'all',
      tier: 'all',
      leader: 'any',
      sort: 'composite-desc',
    };

    function matches(tile: HTMLElement): boolean {
      if (state.region !== 'all' && tile.dataset.region !== state.region) return false;
      if (state.tier !== 'all' && tile.dataset.tier !== state.tier) return false;
      if (state.leader !== 'any' && tile.dataset.leader !== state.leader) return false;
      return true;
    }

    function compare(a: HTMLElement, b: HTMLElement): number {
      const aFloored = a.dataset.floored === 'true';
      const bFloored = b.dataset.floored === 'true';
      // Floored always last regardless of sort
      if (aFloored && !bFloored) return 1;
      if (!aFloored && bFloored) return -1;

      if (state.sort === 'composite-desc') return Number(b.dataset.score) - Number(a.dataset.score);
      if (state.sort === 'composite-asc') return Number(a.dataset.score) - Number(b.dataset.score);
      if (state.sort === 'name') {
        const an = a.dataset.nameEn ?? '';
        const bn = b.dataset.nameEn ?? '';
        return an.localeCompare(bn);
      }
      return 0;
    }

    function apply() {
      let shown = 0;
      const ordered = [...tiles].sort(compare);
      ordered.forEach((tile, idx) => {
        const visible = matches(tile);
        tile.classList.toggle('is-hidden', !visible);
        // Use CSS order to re-sort without mutating DOM tree (preserves event listeners)
        tile.style.order = String(idx);
        if (visible) shown++;
      });
      if (showCounter) showCounter.textContent = String(shown);
      // Top-5 eyebrow only meaningful when sort is composite-desc
      if (eyebrow) eyebrow.classList.toggle('is-hidden', state.sort !== 'composite-desc');
    }

    function bindGroup(filterKey: keyof State, mode: 'exclusive' | 'toggle' = 'exclusive') {
      const group = root.querySelector<HTMLElement>(`[data-filter="${filterKey}"]`);
      if (!group) return;
      group.querySelectorAll<HTMLButtonElement>('button[data-value]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const val = btn.dataset.value ?? '';
          if (mode === 'toggle') {
            // Toggle: if pressing the active one, return to "any"; otherwise select this one
            if (state[filterKey] === val) {
              state[filterKey] = filterKey === 'leader' ? 'any' : 'all';
            } else {
              state[filterKey] = val;
            }
          } else {
            state[filterKey] = val;
          }
          // Update aria-pressed across the group
          group.querySelectorAll<HTMLButtonElement>('button[data-value]').forEach((b) => {
            const isActive =
              (mode === 'toggle' && b.dataset.value === state[filterKey]) ||
              (mode === 'exclusive' && b.dataset.value === state[filterKey]) ||
              (mode === 'toggle' && state[filterKey] === 'any' && b.dataset.value === 'any');
            b.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          });
          apply();
        });
      });
    }

    bindGroup('region');
    bindGroup('tier');
    bindGroup('leader', 'toggle');
    bindGroup('sort');

    // Initial render
    apply();
  });
</script>
