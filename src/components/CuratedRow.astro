---
/**
 * "Provinces people search for" — a 5-tile curated row above the full 77.
 * Recognizable destinations in provincial form: Bangkok (capital), Chiang Mai
 * (north), Phuket (south island), Chonburi (Pattaya is here), Surat Thani
 * (Samui/Phangan/Tao are here). Pattaya and Samui aren't provinces; we map
 * them to their host provinces honestly.
 *
 * Tiles render at the canonical rank (not 1–5) so the user sees how their
 * familiar destinations land within the full distribution. No podium accent
 * here — that's reserved for the all-77 grid.
 */
import type { Province, Locale } from '../data/types';
import ProvinceTile from './ProvinceTile.astro';

interface Props {
  provinces: Province[];
  locale: Locale;
  /** Province slugs to feature, in order. Defaults to the canonical 5. */
  ids?: string[];
}
const DEFAULT_IDS = ['bangkok', 'chiang-mai', 'phuket', 'chonburi', 'surat-thani'];
const { provinces, locale, ids = DEFAULT_IDS } = Astro.props;

const byId = new Map(provinces.map((p) => [p.id, p]));
const featured = ids
  .map((id) => byId.get(id))
  .filter((p): p is Province => p !== undefined);
---
{featured.length > 0 && (
  <div class="tli-grid tli-grid--curated">
    {featured.map((p) => (
      <ProvinceTile province={p} locale={locale} />
    ))}
  </div>
)}
