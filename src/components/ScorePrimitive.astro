/**
 * Score primitive — the central UI element. PR 3 implements the `chip` scale
 * (used inside indicator tables); the `hero` and `card` panels are kept inline
 * in their host components so they can carry surrounding meta cleanly. The
 * `embed` scale is widget-only and lands when the embed widget ships.
 *
 * Hatch pattern at chip scale is automatic via `.tli-score-chip::before` from
 * components.css — no extra wiring needed here.
 */
import { bandClass, bandLabel } from '../lib/score-band';
import type { Locale } from '../data/types';

interface Props {
  score: number | null;
  scale: 'chip';
  floored?: boolean;
  bandLabelVisible?: boolean;
  locale?: Locale;
  class?: string;
}
const {
  score,
  scale: _scale,
  floored = false,
  bandLabelVisible = true,
  locale = 'en',
  class: extra = '',
} = Astro.props;

const display =
  score === null || floored ? '0' : String(Math.round(score));
const bandCls = bandClass(score, floored);
const label = bandLabel(score, floored, locale).toLowerCase();
// Accessible label combines numeric score + band word so screen readers
// announce both ("Score 65 of 100, good") rather than just the number.
const ariaLabel = locale === 'th'
  ? `คะแนน ${display} จาก 100, ${label}`
  : `Score ${display} of 100, ${label}`;
---
<span
  class:list={['tli-score-chip', bandCls, extra]}
  role="img"
  aria-label={ariaLabel}
>
  <span class="tli-score-chip__num" aria-hidden="true">{display}</span>
  {bandLabelVisible && <span class="tli-score-chip__band" aria-hidden="true">{label}</span>}
</span>
