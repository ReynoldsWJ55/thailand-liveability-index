import scoresData from '../data/scores.json';
import indicatorMeta from '../data/indicator-meta.json';
import type { ScoresFile, CategoryId } from '../data/types';
import { regionLabel, SLUG_MAP, CATEGORIES } from '../data/lookups';
import { IN_DEVELOPMENT_INDICATORS } from '../data/in-development-indicators';
import Lucide from './Lucide.astro';

interface Props {
  locale: 'en' | 'th';
  /** The current path WITHOUT the leading locale prefix, e.g. '/' or '/methodology/'. */
  pathInLocale?: string;
}
const { locale, pathInLocale = '/' } = Astro.props;
const enHref = `/en${pathInLocale}`;
const thHref = `/th${pathInLocale}`;

// Combined search index — provinces + indicators, both inlined into the page
// so the combobox is fully client-side without a fetch. Each entry has a
// `kind` discriminator so the renderer can label and route appropriately.
const data = scoresData as ScoresFile;
const provinceIndex = data.provinces.map((p) => ({
  kind: 'province' as const,
  id: p.id,
  name_en: p.name_en,
  name_th: p.name_th,
  meta: regionLabel(p.region, locale),
  score: p.floored ? 0 : (p.composite ?? 0),
  floored: p.floored,
  href: `/${locale}/${p.id}/`,
}));

// Indicator entries — keyed by SLUG_MAP for SEO-friendly URLs.
interface IndicatorMetaShape {
  id: string;
  label_en: string;
  label_th: string;
  unit: string;
  category: CategoryId;
}
const indicatorIndex = Object.values(indicatorMeta as Record<string, IndicatorMetaShape>).map((m) => ({
  kind: 'indicator' as const,
  id: m.id,
  name_en: m.label_en,
  name_th: m.label_th,
  meta: locale === 'th' ? CATEGORIES[m.category].label_th : CATEGORIES[m.category].label_en,
  score: 0,
  floored: false,
  href: `/${locale}/indicators/${SLUG_MAP[m.id] ?? m.id}/`,
}));

// In-development indicators are searchable too — they have stable URLs.
const inDevIndex = IN_DEVELOPMENT_INDICATORS.map((m) => ({
  kind: 'indicator-dev' as const,
  id: m.id,
  name_en: m.label_en,
  name_th: m.label_th,
  meta: locale === 'th'
    ? `${CATEGORIES[m.category].label_th} · พัฒนา`
    : `${CATEGORIES[m.category].label_en} · in dev`,
  score: 0,
  floored: false,
  href: `/${locale}/indicators/in-development/${m.slug}/`,
}));

const indexJson = JSON.stringify([...provinceIndex, ...indicatorIndex, ...inDevIndex]);

const placeholder = locale === 'th' ? 'ค้นหาจังหวัดหรือตัวชี้วัด…' : 'Find a province or indicator…';
const clearLabel = locale === 'th' ? 'ล้าง' : 'Clear';
const searchLabel = locale === 'th' ? 'ค้นหาจังหวัด' : 'Find a province';
const noResults = locale === 'th' ? 'ไม่พบจังหวัด' : 'No provinces match';
const totalLabel = locale === 'th' ? `${data.provinces.length} จังหวัด` : `${data.provinces.length} provinces`;

// Primary nav links — kept terse so the bar still reads cleanly with the
// province search. Indicators is the most useful sibling to province pages
// (cross-section view); methodology answers "how is this scored" for any
// page; developers is the data/embed hub.
const navItems = locale === 'th'
  ? [
      { href: '/th/indicators/', label: 'ตัวชี้วัด', match: '/indicators' },
      { href: '/th/methodology/', label: 'ระเบียบวิธี', match: '/methodology' },
      { href: '/th/developers/', label: 'นักพัฒนา', match: '/developers' },
    ]
  : [
      { href: '/en/indicators/', label: 'Indicators', match: '/indicators' },
      { href: '/en/methodology/', label: 'Methodology', match: '/methodology' },
      { href: '/en/developers/', label: 'Developers', match: '/developers' },
    ];
function isCurrent(match: string) {
  return pathInLocale.startsWith(match);
}
---
<header class="tli-nav">
  <div class="tli-nav__inner">
    <a class="tli-nav__brand" href={`/${locale}/`} aria-label="Thailand Liveability Index — home">
      TLI<span class="tli-nav__brand-dot">.</span>
    </a>

    <form
      class="tli-nav__search"
      role="search"
      data-component="province-search"
      data-locale={locale}
      autocomplete="off"
      onsubmit="return false;"
    >
      <Lucide name="search" size={14} class="tli-nav__search-icon" />
      <input
        id="tli-province-search"
        class="tli-nav__search-input"
        type="search"
        placeholder={placeholder}
        autocomplete="off"
        spellcheck="false"
        role="combobox"
        aria-expanded="false"
        aria-controls="tli-province-suggestions"
        aria-autocomplete="list"
        aria-label={searchLabel}
        {...locale === 'th' ? { lang: 'th' } : {}}
      />
      <button
        type="button"
        class="tli-nav__search-clear"
        aria-label={clearLabel}
        hidden
      >
        <Lucide name="x" size={12} />
      </button>
      <ul
        id="tli-province-suggestions"
        class="tli-nav__search-list"
        role="listbox"
        aria-label={searchLabel}
        hidden
      ></ul>
      <span class="tli-nav__search-status" aria-live="polite" aria-atomic="true"></span>
      <script type="application/json" data-province-index set:html={indexJson} />
      <span data-no-results-text hidden>{noResults}</span>
      <span data-total-text hidden>{totalLabel}</span>
    </form>

    <nav class="tli-nav__primary" aria-label={locale === 'th' ? 'เมนูหลัก' : 'Primary'}>
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`tli-nav__primary-link${isCurrent(item.match) ? ' is-current' : ''}`}
          aria-current={isCurrent(item.match) ? 'page' : 'false'}
          {...locale === 'th' ? { lang: 'th' } : {}}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <nav class="tli-nav__lang" aria-label="Language">
      <a href={enHref} aria-current={locale === 'en' ? 'true' : 'false'}>EN</a>
      <a href={thHref} aria-current={locale === 'th' ? 'true' : 'false'}>TH</a>
    </nav>
  </div>
</header>

<script>
  // Province search — vanilla combobox.
  // Pattern: WAI-ARIA combobox with manual focus management and arrow-key
  // navigation. Suggestions render up to 8 matches ranked by:
  //   1. exact name match (EN or TH)
  //   2. starts-with match (locale-preferred)
  //   3. word-start match (e.g. "ayut" → "Phra Nakhon Si Ayutthaya")
  //   4. contains match
  //   5. region-name match (lowest weight)
  // No external lib — fast enough for 77 entries.
  type Entry = {
    kind: 'province' | 'indicator' | 'indicator-dev';
    id: string;
    name_en: string;
    name_th: string;
    meta: string;
    score: number;
    floored: boolean;
    href: string;
  };

  document.querySelectorAll<HTMLFormElement>('[data-component="province-search"]').forEach((root) => {
    const locale = (root.dataset.locale as 'en' | 'th') ?? 'en';
    const input = root.querySelector<HTMLInputElement>('.tli-nav__search-input');
    const list = root.querySelector<HTMLUListElement>('.tli-nav__search-list');
    const clearBtn = root.querySelector<HTMLButtonElement>('.tli-nav__search-clear');
    const status = root.querySelector<HTMLElement>('.tli-nav__search-status');
    const indexEl = root.querySelector<HTMLScriptElement>('[data-province-index]');
    const noResultsText = root.querySelector<HTMLElement>('[data-no-results-text]')?.textContent ?? 'No matches';
    if (!input || !list || !indexEl) return;

    const entries: Entry[] = JSON.parse(indexEl.textContent ?? '[]');
    let activeIndex = -1;
    let currentMatches: Entry[] = [];

    function score(p: Entry, q: string): number {
      const ql = q.toLowerCase();
      const en = p.name_en.toLowerCase();
      const th = p.name_th;
      const meta = p.meta.toLowerCase();
      // Exact match either locale
      if (en === ql || th === q) return 100;
      // Starts-with — preferred locale first
      const primary = locale === 'th' ? th : en;
      const secondary = locale === 'th' ? en : th;
      if (primary.startsWith(locale === 'th' ? q : ql)) return 90;
      if (secondary.toLowerCase().startsWith(ql) || secondary.startsWith(q)) return 80;
      // Word-start — match starts of any whitespace-delimited word
      const enWords = en.split(/\s+/);
      if (enWords.some((w) => w.startsWith(ql))) return 70;
      // Contains
      if (en.includes(ql)) return 50;
      if (th.includes(q)) return 50;
      // Region/category meta (low weight, only if nothing else)
      if (meta.includes(ql)) return 20;
      return 0;
    }

    function rank(q: string): Entry[] {
      if (!q.trim()) return [];
      const matches = entries
        .map((p) => ({ p, s: score(p, q.trim()) }))
        .filter((m) => m.s > 0)
        .sort((a, b) => b.s - a.s || a.p.name_en.localeCompare(b.p.name_en))
        .slice(0, 8)
        .map((m) => m.p);
      return matches;
    }

    function bandClassFor(p: Entry): string {
      if (p.floored) return 'score-0';
      if (p.score >= 80) return 'score-4';
      if (p.score >= 60) return 'score-3';
      if (p.score >= 40) return 'score-2';
      if (p.score >= 20) return 'score-1';
      return 'score-0';
    }

    function render(matches: Entry[]) {
      currentMatches = matches;
      activeIndex = -1;
      input!.setAttribute('aria-expanded', matches.length > 0 ? 'true' : 'false');
      if (matches.length === 0) {
        if (input!.value.trim()) {
          list!.hidden = false;
          list!.innerHTML = `<li class="tli-nav__search-empty" role="presentation">${noResultsText}</li>`;
        } else {
          list!.hidden = true;
          list!.innerHTML = '';
        }
        return;
      }
      list!.hidden = false;
      list!.innerHTML = matches
        .map((p, i) => {
          const name = locale === 'th' ? p.name_th : p.name_en;
          const sub = locale === 'th' ? p.name_en : p.name_th;
          const kindLabel = p.kind === 'indicator-dev'
            ? (locale === 'th' ? 'ตัวชี้วัด · พัฒนา' : 'INDICATOR · IN DEV')
            : p.kind === 'indicator'
              ? (locale === 'th' ? 'ตัวชี้วัด' : 'INDICATOR')
              : (locale === 'th' ? 'จังหวัด' : 'PROVINCE');
          if (p.kind === 'indicator' || p.kind === 'indicator-dev') {
            const klass = p.kind === 'indicator-dev'
              ? 'tli-nav__search-item tli-nav__search-item--indicator tli-nav__search-item--dev'
              : 'tli-nav__search-item tli-nav__search-item--indicator';
            return `<li
              class="${klass}"
              role="option"
              id="tli-search-suggestion-${i}"
              data-href="${p.href}"
              aria-selected="false"
            >
              <span class="tli-nav__search-item-name">${name}</span>
              <span class="tli-nav__search-item-sub">${kindLabel} · ${p.meta}</span>
            </li>`;
          }
          const band = bandClassFor(p);
          const scoreDisplay = p.floored ? '0' : String(p.score);
          return `<li
            class="tli-nav__search-item"
            role="option"
            id="tli-search-suggestion-${i}"
            data-href="${p.href}"
            aria-selected="false"
          >
            <span class="tli-nav__search-item-name">${name}</span>
            <span class="tli-nav__search-item-sub">${kindLabel} · ${sub} · ${p.meta}</span>
            <span class="tli-nav__search-item-score tli-num ${band}">${scoreDisplay}</span>
          </li>`;
        })
        .join('');
      // Click to navigate
      list!.querySelectorAll<HTMLLIElement>('[role="option"]').forEach((li) => {
        li.addEventListener('mousedown', (e) => {
          e.preventDefault();
          goHref(li.dataset.href);
        });
        li.addEventListener('mouseenter', () => {
          const i = Array.from(list!.children).indexOf(li);
          setActive(i);
        });
      });
    }

    function setActive(i: number) {
      const items = list!.querySelectorAll<HTMLLIElement>('[role="option"]');
      items.forEach((el, idx) => {
        const active = idx === i;
        el.setAttribute('aria-selected', active ? 'true' : 'false');
        el.classList.toggle('is-active', active);
      });
      activeIndex = i;
      if (i >= 0 && items[i]) {
        input!.setAttribute('aria-activedescendant', items[i].id);
      } else {
        input!.removeAttribute('aria-activedescendant');
      }
    }

    function goHref(href: string | undefined) {
      if (!href) return;
      window.location.href = href;
    }

    function close() {
      list!.hidden = true;
      list!.innerHTML = '';
      input!.setAttribute('aria-expanded', 'false');
      input!.removeAttribute('aria-activedescendant');
      activeIndex = -1;
      currentMatches = [];
    }

    input.addEventListener('input', () => {
      const q = input.value;
      clearBtn!.hidden = q.length === 0;
      render(rank(q));
      if (status) status.textContent = currentMatches.length === 0 && q.trim() ? noResultsText : '';
    });

    input.addEventListener('keydown', (e) => {
      const items = list!.querySelectorAll<HTMLLIElement>('[role="option"]');
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (items.length === 0) return;
        setActive((activeIndex + 1) % items.length);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (items.length === 0) return;
        setActive(activeIndex <= 0 ? items.length - 1 : activeIndex - 1);
      } else if (e.key === 'Enter') {
        e.preventDefault();
        const target = activeIndex >= 0 ? currentMatches[activeIndex] : currentMatches[0];
        if (target) goHref(target.href);
      } else if (e.key === 'Escape') {
        if (input.value) {
          input.value = '';
          clearBtn!.hidden = true;
        }
        close();
      }
    });

    clearBtn!.addEventListener('click', () => {
      input.value = '';
      clearBtn!.hidden = true;
      close();
      input.focus();
    });

    input.addEventListener('blur', () => {
      // Delay so click on a suggestion can fire first
      setTimeout(() => close(), 120);
    });

    input.addEventListener('focus', () => {
      if (input.value.trim()) render(rank(input.value));
    });
  });
</script>
