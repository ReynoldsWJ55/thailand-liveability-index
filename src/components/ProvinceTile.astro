/**
 * Single province tile. Walk Score-shaped: rank top-left, score dominant
 * right (mono numeral, band-colored), name middle-left, "leads on
 * <category>" footnote at the bottom.
 *
 * Floored variant adds a "Floored · <category> 0" chip beneath the leader bar.
 *
 * Podium variants — for top-of-grid affordance per iter3 spec — render as
 * variable-weight brand stripes across the top edge of the tile:
 *   podium=1 → 2px solid brand
 *   podium=2 → 1.5px solid brand
 *   podium=3 → 1px solid brand
 *   podium=4|5 → hairline brand at 60% alpha
 *   podium=null → no stripe
 *
 * Brand color (NOT a score-band color) — keeps the "score colors only on
 * scores" rule clean.
 */
import type { Province, Locale } from '../data/types';
import { CATEGORIES, CHROME } from '../data/lookups';
import { scoreBand } from '../lib/score-band';

type PodiumRank = 1 | 2 | 3 | 4 | 5 | null;

interface Props {
  province: Province;
  locale: Locale;
  /** Override the displayed rank (e.g. when filtered list re-numbers). Defaults to the canonical rank. */
  rank?: number;
  /** Top-of-grid podium accent. */
  podium?: PodiumRank;
}
const { province, locale, rank: rankOverride, podium = null } = Astro.props;
const C = CHROME[locale];
const rank = rankOverride ?? province.rank;
const name = locale === 'th' ? province.name_th : province.name_en;

const floored = province.floored;
const score = floored ? 0 : (province.composite ?? 0);
const band = floored ? 0 : scoreBand(province.composite ?? 0);

const leaderId = Object.values(province.categories).sort((a, b) => b.score - a.score)[0]?.id ?? 'climate';
const leaderCat = CATEGORIES[leaderId];
const flooredCat = floored && province.floored_by ? CATEGORIES[province.floored_by] : null;

// All metadata exposed as data-* so the Controls island can filter without
// re-rendering — DOM stays static, visibility toggles via classlist.
const dataset: Record<string, string> = {
  'data-tile': '',
  'data-province-id': province.id,
  'data-region': province.region,
  'data-tier': String(province.coverage_tier),
  'data-leader': leaderId,
  'data-score': String(score),
  'data-rank': String(province.rank),
  'data-floored': floored ? 'true' : 'false',
  'data-name-en': province.name_en.toLowerCase(),
  'data-name-th': province.name_th,
};

const podiumClass = podium === null ? '' : `tli-tile--podium-${podium}`;
const flooredClass = floored ? 'tli-tile--floored' : '';
const tileHref = `/${locale}/${province.id}/`;
---
<a
  href={tileHref}
  class:list={['tli-tile', `score-${band}`, podiumClass, flooredClass]}
  {...dataset}
>
  <span class="tli-tile__podium" aria-hidden="true"></span>
  <span class="tli-tile__stripe" aria-hidden="true"></span>
  <span class="tli-tile__body">
    <span class="tli-tile__rank">#{rank}</span>
    <span class="tli-tile__score tli-num" style={floored ? '' : `color: var(--score-${band});`}>
      {floored ? '0' : score}
    </span>
    <span class="tli-tile__name">
      {name}
      {locale === 'th' && (
        <span class="tli-tile__name-en">{province.name_en}</span>
      )}
    </span>
    <span class="tli-tile__leader">
      <span class:list={['tli-cat-dot', leaderCat.cssClass]} aria-hidden="true"></span>
      <span class="tli-tile__leader-text">{C.leadsOn}</span>
      <span class="tli-tile__leader-name">
        {locale === 'th' ? leaderCat.label_th : leaderCat.label_en}
      </span>
    </span>
    {floored && flooredCat && (
      <span class="tli-tile__floored-chip">
        {C.flooredBy(locale === 'th' ? flooredCat.label_th : flooredCat.label_en)}
      </span>
    )}
  </span>
</a>
