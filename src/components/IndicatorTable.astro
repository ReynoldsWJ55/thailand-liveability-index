/**
 * Indicator detail block — Block 1.5 expandable cards.
 *
 * Replaces the prior <table> layout with a CSS-grid <details> stack. Each
 * indicator is its own native disclosure widget:
 * - Summary row carries the same 5-column visual (name, value, score, source, AS OF)
 * - Expanded body carries rich content scaffold (what it measures, how to
 *   read the score, source attribution, methodology link)
 *
 * Why <details>:
 * - Native browser handling: keyboard, screen-reader, mobile out of the box
 * - SEO + AI: all content is in the DOM regardless of expand state; semantic
 *   disclosure pattern is explicit ("this is expandable detail") so AI scrapers
 *   (Perplexity, ChatGPT, Claude) cite the rich content with confidence
 * - No JS required; works with JS disabled
 *
 * Block 3 applicability override (Bangkok N/A) preserved.
 * Block 1 indicator display ordering preserved.
 *
 * Rich content authoring (per-indicator Thailand-specific framing) lands at
 * Block 10 wk 6 alongside the v1.2 methodology spike. v0.1 content uses
 * indicator-meta.source_description + score-band interpretation as scaffold.
 */
import { CATEGORIES, CATEGORY_ANCHOR, categoryLabel, CHROME, indicatorDisplayRank, indicatorDescription } from '../data/lookups';
import { getApplicabilityOverride } from '../data/applicability_overrides';
import type { CategoryScore, Indicator, Locale, ScoresFile } from '../data/types';
import scoresData from '../data/scores.json';
import Lucide from './Lucide.astro';
import ScorePrimitive from './ScorePrimitive.astro';
import ProvenanceChip from './ProvenanceChip.astro';
import CitationRow from './CitationRow.astro';

// Compute per-indicator distribution stats ONCE at module load (cached for
// the whole build). Each render reuses the cached map. Stats power the
// "Where this province falls" detail block (rank + min/max/median range).
type IndStat = { values: { id: string; value: number; raw_score: number }[]; min: number; max: number; median: number };
const _allData = scoresData as ScoresFile;
const _indStats = new Map<string, IndStat>();
for (const p of _allData.provinces) {
  for (const cat of Object.values(p.categories)) {
    for (const ind of cat.indicators) {
      if (ind.quality_flag === 'missing' || typeof ind.value !== 'number') continue;
      const stat = _indStats.get(ind.id) ?? { values: [], min: Infinity, max: -Infinity, median: 0 };
      stat.values.push({ id: p.id, value: ind.value, raw_score: ind.raw_score });
      _indStats.set(ind.id, stat);
    }
  }
}
for (const stat of _indStats.values()) {
  const sorted = [...stat.values].sort((a, b) => a.value - b.value);
  stat.min = sorted[0].value;
  stat.max = sorted[sorted.length - 1].value;
  stat.median = sorted[Math.floor(sorted.length / 2)].value;
  stat.values = sorted;
}

function fmtNum(n: number): string {
  if (Number.isInteger(n)) return n.toLocaleString('en-US');
  return n.toLocaleString('en-US', { maximumFractionDigits: 2 });
}

/**
 * Distribution stats for a single (province, indicator). Computes rank by
 * raw_score (higher = better rank since score is already normalized for
 * direction). Returns undefined when no values exist.
 */
function distributionFor(provinceId: string, indicatorId: string) {
  const stat = _indStats.get(indicatorId);
  if (!stat) return undefined;
  // Sort by raw_score DESCENDING (highest score = rank 1)
  const byScore = [...stat.values].sort((a, b) => b.raw_score - a.raw_score);
  const rank = byScore.findIndex((v) => v.id === provinceId) + 1;
  return {
    rank: rank > 0 ? rank : undefined,
    n: stat.values.length,
    min: stat.min,
    max: stat.max,
    median: stat.median,
  };
}

interface Props {
  category: CategoryScore;
  locale: Locale;
  isFloor?: boolean;
  provinceId: string;
  /** Display name of the parent province for SEO-friendly indicator-card prose. */
  provinceName: string;
}
const { category, locale, isFloor = false, provinceId, provinceName } = Astro.props;
const meta = CATEGORIES[category.id];
const label = categoryLabel(category.id, locale);
const C = CHROME[locale];

function indicatorLabel(ind: Indicator): string {
  return locale === 'th' ? ind.label_th : ind.label_en;
}

function fmtValue(ind: Indicator): string {
  if (ind.quality_flag === 'missing') return '—';
  if (Number.isInteger(ind.value)) return ind.value.toLocaleString('en-US');
  return ind.value.toLocaleString('en-US', { maximumFractionDigits: 2 });
}

/** Score-band interpretation. EN+TH map. Same band thresholds as ScorePrimitive. */
function scoreBandText(score: number, loc: Locale): string {
  const bands = loc === 'th'
    ? [
        { max: 20, text: 'ห้าส่วนล่าง — ห่างจากเกณฑ์ระเบียบวิธีอย่างมีนัยสำคัญ' },
        { max: 40, text: 'ต่ำกว่าค่าเฉลี่ย' },
        { max: 60, text: 'ระดับกลาง' },
        { max: 80, text: 'สูงกว่าค่าเฉลี่ย' },
        { max: 101, text: 'ห้าส่วนบน — ถึงหรือเกินเกณฑ์ระเบียบวิธี' },
      ]
    : [
        { max: 20, text: 'Bottom quintile — significant gap vs. methodology benchmarks' },
        { max: 40, text: 'Below average — room for improvement' },
        { max: 60, text: 'Mid-range — typical for Thai provinces' },
        { max: 80, text: 'Above average — meets methodology benchmarks' },
        { max: 101, text: 'Top quintile — meets or exceeds methodology benchmarks' },
      ];
  return bands.find((b) => score < b.max)?.text ?? '';
}

// Sort N/A indicators to the bottom of the category for cleaner default view.
// Within applicable + N/A buckets, preserve the topical pairing from
// indicatorDisplayRank.
const sortedIndicators = [...category.indicators].sort((a, b) => {
  const aOverride = getApplicabilityOverride(provinceId, a.id);
  const bOverride = getApplicabilityOverride(provinceId, b.id);
  // N/A goes after applicable
  if (!!aOverride !== !!bOverride) return aOverride ? 1 : -1;
  // Within bucket, use display rank
  return indicatorDisplayRank(a.id) - indicatorDisplayRank(b.id);
});
const sources = Array.from(new Set(sortedIndicators.map((i) => i.source)));

const labels = locale === 'th'
  ? {
      whatThisMeasures: 'ตัวชี้วัดนี้วัดอะไร',
      howToReadScore: 'วิธีอ่านคะแนนนี้',
      whereThisFalls: 'จังหวัดนี้อยู่ในช่วงใดของไทย',
      rankOfN: (rank: number, n: number) => `อันดับ ${rank} จาก ${n}`,
      rangeText: (min: string, median: string, max: string, unit: string) =>
        `ค่าต่ำสุด-สูงสุดของไทย: ${min}–${max} ${unit} (มัธยฐาน ${median})`,
      sourceHeading: 'แหล่งข้อมูล',
      whyNa: 'ทำไมจึงเป็น N/A',
    }
  : {
      whatThisMeasures: 'What this measures',
      howToReadScore: 'How to read this score',
      whereThisFalls: 'Where this province falls',
      rankOfN: (rank: number, n: number) => `Rank ${rank} of ${n} provinces`,
      rangeText: (min: string, median: string, max: string, unit: string) =>
        `Thailand range: ${min}–${max} ${unit} (median ${median})`,
      sourceHeading: 'Source',
      whyNa: 'Why N/A here',
    };
---
<section class="section" id={CATEGORY_ANCHOR[category.id]}>
  <div class="section__head">
    <h2 class="section__title" {...locale === 'th' ? { lang: 'th' } : {}}>
      {label} · <span class="section__title-sub">{C.indicatorDetail}</span>
    </h2>
    <span class="section__sub">{C.indicatorCount(category.indicator_count)}</span>
  </div>

  <div class="ind-block">
    <div class="ind-block__head">
      <Lucide name={meta.icon} size={20} class="ind-block__icon" />
      <h3 {...locale === 'th' ? { lang: 'th' } : {}}>{label}</h3>
      <ScorePrimitive score={category.score} scale="chip" floored={isFloor} locale={locale} />
      <ProvenanceChip variant="fresh">{C.asOf} {category.freshest_as_of}</ProvenanceChip>
    </div>

    <div class="ind-cards" role="list">
      <div class="ind-cards__header" aria-hidden="true">
        <span class="ind-cards__col-name" {...locale === 'th' ? { lang: 'th' } : {}}>{C.indicator}</span>
        <span class="ind-cards__col-value" {...locale === 'th' ? { lang: 'th' } : {}}>{C.value}</span>
        <span class="ind-cards__col-score" {...locale === 'th' ? { lang: 'th' } : {}}>{C.score0to100}</span>
        <span class="ind-cards__col-asof" {...locale === 'th' ? { lang: 'th' } : {}}>{C.asOfHeader}</span>
        <span class="ind-cards__col-chevron" aria-hidden="true"></span>
      </div>

      {sortedIndicators.map((ind) => {
        const override = getApplicabilityOverride(provinceId, ind.id);
        const isInherited = ind.quality_flag === 'inherited' && ind.inherited_from;
        const isMissing = ind.quality_flag === 'missing';
        // DefinedTerm schema for AI/SEO — each indicator gets a scoped record
        // so AI scrapers can match queries against the indicator concept.
        const definedTermSchema = {
          '@context': 'https://schema.org',
          '@type': 'DefinedTerm',
          name: locale === 'th' ? ind.label_th : ind.label_en,
          alternateName: locale === 'th' ? ind.label_en : ind.label_th,
          description: `${locale === 'th' ? ind.label_th : ind.label_en} (${ind.unit}). Source: ${ind.source}.`,
          inDefinedTermSet: 'https://thailandliveabilityindex.com/en/methodology/',
        };
        return (
          <details class="ind-card" role="listitem" name={`ind-${category.id}`}>
            <summary class="ind-card__summary">
              <span class="ind-card__name" {...locale === 'th' ? { lang: 'th' } : {}}>
                <span class="ind-card__name-label">{indicatorLabel(ind)}</span>
                <span class="ind-card__name-unit tli-caption">{ind.unit}</span>
              </span>
              <span class="ind-card__value">
                {isMissing ? '—' : fmtValue(ind)}
              </span>
              <span class="ind-card__score">
                {override ? (
                  <ProvenanceChip
                    variant="na"
                    title={locale === 'th' ? override.rationale_th : override.rationale_en}
                  >
                    {C.naLabel}
                  </ProvenanceChip>
                ) : isMissing ? (
                  <ProvenanceChip variant="missing">{C.noData}</ProvenanceChip>
                ) : isInherited && ind.inherited_from ? (
                  <ProvenanceChip variant="inherit" icon="corner-down-right">
                    {C.inheritedFrom(ind.inherited_from)}
                  </ProvenanceChip>
                ) : (
                  <ScorePrimitive
                    score={ind.raw_score}
                    scale="chip"
                    floored={ind.raw_score === 0 && isFloor}
                    locale={locale}
                    bandLabelVisible={false}
                  />
                )}
              </span>
              <span class="ind-card__asof">{ind.as_of}</span>
              <span class="ind-card__chevron" aria-hidden="true">
                <Lucide name="info" size={14} />
              </span>
            </summary>

            <div class="ind-card__detail">
              <script type="application/ld+json" set:html={JSON.stringify(definedTermSchema)} />

              {(() => {
                const dist = !override && !isMissing ? distributionFor(provinceId, ind.id) : undefined;
                return (
                  <div class="ind-card__detail-grid">
                    <section class="ind-card__detail-block ind-card__detail-block--wide">
                      <h4>{labels.whatThisMeasures}</h4>
                      {(() => {
                        const desc = indicatorDescription(ind.id, locale);
                        // Province-specific lede uses the actual value; SEO/AI gold.
                        if (override) {
                          return (
                            <p {...locale === 'th' ? { lang: 'th' } : {}}>
                              <strong>{provinceName}</strong>{' '}
                              {locale === 'th'
                                ? `ไม่มีคะแนนสำหรับ ${indicatorLabel(ind)} — ดูเหตุผล N/A ด้านล่าง.`
                                : `does not score on ${indicatorLabel(ind)} — see the N/A rationale below.`}
                              {desc && <> {desc}</>}
                            </p>
                          );
                        }
                        if (isMissing) {
                          return (
                            <p {...locale === 'th' ? { lang: 'th' } : {}}>
                              {locale === 'th'
                                ? `ข้อมูล ${indicatorLabel(ind)} ของ ${provinceName} ยังไม่มี.`
                                : `${indicatorLabel(ind)} data for ${provinceName} is not yet available.`}
                              {desc && <> {desc}</>}
                            </p>
                          );
                        }
                        const valueStr = fmtValue(ind);
                        return (
                          <p {...locale === 'th' ? { lang: 'th' } : {}}>
                            <strong>{provinceName}</strong>{' '}
                            {locale === 'th'
                              ? `มี ${indicatorLabel(ind)} เท่ากับ ${valueStr} ${ind.unit}.`
                              : `has a ${indicatorLabel(ind)} of ${valueStr} ${ind.unit}.`}
                            {desc && <> {desc}</>}
                          </p>
                        );
                      })()}
                    </section>

                    {!override && !isMissing && (
                      <section class="ind-card__detail-block">
                        <h4>{labels.howToReadScore}</h4>
                        <p {...locale === 'th' ? { lang: 'th' } : {}}>
                          {scoreBandText(ind.raw_score, locale)}
                        </p>
                      </section>
                    )}

                    {dist && dist.rank && (
                      <section class="ind-card__detail-block ind-card__detail-block--wide">
                        <h4>{labels.whereThisFalls}</h4>
                        <p {...locale === 'th' ? { lang: 'th' } : {}}>
                          <strong>{labels.rankOfN(dist.rank, dist.n)}</strong>
                          {' · '}
                          {labels.rangeText(fmtNum(dist.min), fmtNum(dist.median), fmtNum(dist.max), ind.unit)}
                        </p>
                      </section>
                    )}

                    {override && (
                      <section class="ind-card__detail-block ind-card__detail-block--note">
                        <h4>{labels.whyNa}</h4>
                        <p {...locale === 'th' ? { lang: 'th' } : {}}>
                          {locale === 'th' ? override.rationale_th : override.rationale_en}
                        </p>
                      </section>
                    )}

                    <section class="ind-card__detail-block ind-card__detail-block--wide">
                      <h4>{labels.sourceHeading}</h4>
                      <p>
                        <a href={ind.source_url} class="tli-link" target="_blank" rel="noopener">
                          {ind.source} ↗
                        </a>
                        {' · '}
                        <span class="tli-caption">{C.asOf} {ind.as_of}</span>
                      </p>
                    </section>
                  </div>
                );
              })()}
            </div>
          </details>
        );
      })}
    </div>

    <CitationRow
      sources={sources}
      asOf={category.oldest_as_of}
      locale={locale}
      methodologyAnchor={`#${CATEGORY_ANCHOR[category.id]}`}
    />
  </div>
</section>

<style>
  .ind-cards { display: flex; flex-direction: column; gap: 0; }

  .ind-cards__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 14% 16% 14% 28px;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    align-items: center;
    font: var(--fw-semibold) var(--fs-12)/1 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--ink-3);
    background: var(--paper-2);
    border-bottom: 1px solid var(--rule-strong);
  }
  .ind-cards__col-value, .ind-cards__col-score, .ind-cards__col-asof { text-align: right; }

  .ind-card { border-bottom: 1px solid var(--rule); }
  .ind-card[open] { background: var(--paper-2); }
  .ind-card[open] > summary { border-bottom: 1px dashed var(--rule); }

  .ind-card__summary {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 14% 16% 14% 28px;
    gap: var(--sp-3);
    padding: var(--sp-3);
    align-items: center;
    cursor: pointer;
    list-style: none;
    transition: background var(--dur-2) var(--ease-standard);
  }
  .ind-card__summary::-webkit-details-marker { display: none; }
  .ind-card__summary:hover { background: var(--paper-2); }
  .ind-card[open] > .ind-card__summary:hover { background: var(--paper-2); }

  .ind-card__name { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .ind-card__name-label { line-height: var(--lh-tight); overflow-wrap: break-word; }
  .ind-card__name-unit { font-size: var(--fs-12); color: var(--ink-3); }

  .ind-card__value, .ind-card__asof { font-family: var(--font-mono); font-feature-settings: "tnum" 1, "lnum" 1; text-align: right; }
  .ind-card__asof { white-space: nowrap; }
  .ind-card__score { display: flex; justify-content: flex-end; }
  .ind-card__source-summary { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: var(--fs-13); }
  .ind-card__source-summary a { color: var(--brand); text-decoration: none; }
  .ind-card__source-summary a:hover { text-decoration: underline; }

  .ind-card__chevron {
    display: flex; align-items: center; justify-content: center;
    width: 20px; height: 20px;
    color: var(--ink-3);
    transition: transform var(--dur-2) var(--ease-standard);
  }
  .ind-card[open] > .ind-card__summary .ind-card__chevron { transform: rotate(180deg); color: var(--brand); }

  .ind-card__detail { padding: var(--sp-4) var(--sp-5) var(--sp-5); background: var(--paper); }

  .ind-card__detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-5);
  }
  .ind-card__detail-block h4 {
    font: var(--fw-semibold) var(--fs-12)/1 var(--font-sans);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 var(--sp-2) 0;
  }
  .ind-card__detail-block p { margin: 0 0 var(--sp-2) 0; line-height: var(--lh-base); color: var(--ink); }
  .ind-card__detail-block--note { grid-column: 1 / -1; padding: var(--sp-3) var(--sp-4); background: var(--paper-2); border-left: 3px solid var(--ink-3); border-radius: var(--r-1); }
  .ind-card__detail-block--wide { grid-column: 1 / -1; }

  /* Mobile: stack to single column with key:value pairs in summary */
  @media (max-width: 720px) {
    .ind-cards__header { display: none; }
    .ind-card__summary {
      grid-template-columns: 1fr auto auto;
      grid-template-areas:
        "name score chevron"
        "value asof asof";
      gap: var(--sp-2);
    }
    .ind-card__name { grid-area: name; }
    .ind-card__value { grid-area: value; text-align: left; font-size: var(--fs-15); }
    .ind-card__score { grid-area: score; justify-content: flex-end; }
    .ind-card__asof { grid-area: asof; text-align: right; }
    .ind-card__chevron { grid-area: chevron; }
    .ind-card__detail-grid { grid-template-columns: 1fr; gap: var(--sp-4); }
  }
</style>
