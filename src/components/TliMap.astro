/**
 * TliMap — choropleth of all 77 Thai provinces colored by composite score.
 *
 * Renders server-side: SVG paths are computed at build time using the iter2
 * equirectangular projection (aspect-corrected at the mid-latitude). Inline
 * legend overlay sits in the top-right of the canvas (iter3 spec — replaces
 * the iter2 side-by-side legend column). Vanilla JS island handles hover,
 * keyboard activation, and tooltip positioning.
 *
 * Honest-over-clean: provinces without data render in a neutral "no data"
 * treatment, NOT colored as if they scored zero. Zero is a real score
 * reserved for floored provinces (hatched, brick).
 */
import geoData from '../../public/data/geo.json';
import { scoreBand, bandLabel } from '../lib/score-band';
import type { Province, Locale } from '../data/types';
import { CHROME, regionLabel } from '../data/lookups';

interface Props {
  provinces: Province[];
  locale: Locale;
}
const { provinces, locale } = Astro.props;
const C = CHROME[locale];

// Bounding box of Thailand (Phuket → Chiang Rai → Mekong corner → southern peninsula).
const BBOX = { minLon: 97.34, maxLon: 105.64, minLat: 5.61, maxLat: 20.46 };
const W = 460;
const PAD = 8;
const midLat = (BBOX.minLat + BBOX.maxLat) / 2;
const cosMid = Math.cos((midLat * Math.PI) / 180);
const lonRange = (BBOX.maxLon - BBOX.minLon) * cosMid;
const latRange = BBOX.maxLat - BBOX.minLat;
const innerW = W - PAD * 2;
const scale = innerW / lonRange;
const innerH = latRange * scale;
const H = innerH + PAD * 2;

function project([lon, lat]: [number, number]): [number, number] {
  const x = PAD + (lon - BBOX.minLon) * cosMid * scale;
  const y = PAD + (BBOX.maxLat - lat) * scale;
  return [x, y];
}

function ringToPath(ring: [number, number][]): string {
  if (!ring || ring.length < 3) return '';
  let d = '';
  for (let i = 0; i < ring.length; i++) {
    const [x, y] = project(ring[i]);
    d += (i === 0 ? 'M' : 'L') + x.toFixed(1) + ' ' + y.toFixed(1);
  }
  return d + 'Z';
}

// Index sample data by province id for O(1) lookup against the 77 geo entries.
const byId = new Map<string, Province>();
for (const p of provinces) byId.set(p.id, p);

// Build the path data for every province in the geo file — including those
// without scores. "No data" provinces render in a paper-tone fill and don't
// participate in hover. When R2 wires up, every province will have data.
const geo = geoData as unknown as Record<string, [number, number][][]>;
const features = Object.keys(geo)
  .sort()
  .map((id) => {
    const rings = geo[id];
    if (!rings || rings.length === 0) return null;
    const province = byId.get(id);
    const d = rings.map(ringToPath).join(' ');
    if (!province) {
      return {
        id,
        d,
        hasData: false as const,
      };
    }
    const band = province.floored ? 0 : scoreBand(province.composite ?? 0);
    return {
      id,
      d,
      hasData: true as const,
      province,
      band,
      bandWord: bandLabel(province.composite, province.floored, locale),
      regionLabel: regionLabel(province.region, locale),
      score: province.floored ? 0 : (province.composite ?? 0),
      floored: province.floored,
    };
  })
  .filter((f): f is NonNullable<typeof f> => f !== null);

// Region labels — placed in negative space outside Thailand's silhouette.
const regionLabels = [
  { key: 'NORTH', label_en: 'NORTH', label_th: 'เหนือ', lon: 97.9, lat: 19.9 },
  { key: 'NORTHEAST', label_en: 'NORTHEAST', label_th: 'อีสาน', lon: 105.2, lat: 17.8 },
  { key: 'CENTRAL', label_en: 'CENTRAL', label_th: 'กลาง', lon: 99.4, lat: 13.5 },
  { key: 'EAST', label_en: 'EAST', label_th: 'ตะวันออก', lon: 103.7, lat: 12.0 },
  { key: 'SOUTH', label_en: 'SOUTH', label_th: 'ใต้', lon: 102.5, lat: 7.5 },
];

const [bkkX, bkkY] = project([100.5, 13.75]);

const totalRendered = features.length;
const withData = features.filter((f) => f.hasData).length;
---
<div class="tli-map" data-component="tli-map" aria-label={C.mapAriaLabel}>
  <div class="tli-map__canvas">
    <svg
      class="tli-map__svg"
      viewBox={`0 0 ${W} ${H.toFixed(1)}`}
      role="img"
      aria-label={C.mapAriaLabel}
      preserveAspectRatio="xMidYMid meet"
    >
      <defs>
        <pattern
          id="tli-hatch-floored"
          patternUnits="userSpaceOnUse"
          width="6"
          height="6"
          patternTransform="rotate(45)"
        >
          <rect width="6" height="6" fill="var(--score-0)"></rect>
          <line x1="0" y1="0" x2="0" y2="6" stroke="rgba(255,255,255,0.45)" stroke-width="2"></line>
        </pattern>
        <pattern
          id="tli-hatch-nodata"
          patternUnits="userSpaceOnUse"
          width="5"
          height="5"
          patternTransform="rotate(45)"
        >
          <rect width="5" height="5" fill="var(--paper-3)"></rect>
          <line x1="0" y1="0" x2="0" y2="5" stroke="var(--paper-2)" stroke-width="1.4"></line>
        </pattern>
      </defs>

      {regionLabels.map((rl) => {
        const [x, y] = project([rl.lon, rl.lat]);
        const text = locale === 'th' ? rl.label_th : rl.label_en;
        return (
          <text
            x={x.toFixed(1)}
            y={y.toFixed(1)}
            class="tli-map__region-label"
            text-anchor="middle"
          >{text}</text>
        );
      })}

      {features.map((f) => {
        if (!f.hasData) {
          return (
            <path
              d={f.d}
              fill="url(#tli-hatch-nodata)"
              stroke="var(--paper)"
              stroke-width="0.5"
              class="tli-map__province tli-map__province--nodata"
              data-province-id={f.id}
            >
              <title>{f.id.replace(/-/g, ' ')} · {C.noData}</title>
            </path>
          );
        }
        const fill = f.floored ? 'url(#tli-hatch-floored)' : `var(--score-${f.band})`;
        const tooltipBand = f.floored ? C.flooredShort : f.bandWord;
        return (
          <path
            d={f.d}
            fill={fill}
            stroke="var(--paper)"
            stroke-width="0.5"
            class="tli-map__province"
            data-province-id={f.id}
            data-province-name={locale === 'th' ? f.province.name_th : f.province.name_en}
            data-province-region={f.regionLabel}
            data-province-score={f.score}
            data-province-band={tooltipBand}
            data-province-floored={f.floored ? 'true' : 'false'}
            tabindex="0"
            role="link"
          >
            <title>{(locale === 'th' ? f.province.name_th : f.province.name_en)} · {f.score}</title>
          </path>
        );
      })}

      {/* Bangkok marker — small ring so the capital is identifiable */}
      <g pointer-events="none" class="tli-map__capital">
        <circle cx={bkkX.toFixed(1)} cy={bkkY.toFixed(1)} r="3.5" fill="none" stroke="var(--ink)" stroke-width="1.25"></circle>
        <circle cx={bkkX.toFixed(1)} cy={bkkY.toFixed(1)} r="1" fill="var(--ink)"></circle>
        <text x={(bkkX + 6).toFixed(1)} y={(bkkY + 3).toFixed(1)} class="tli-map__capital-label">
          {locale === 'th' ? 'กรุงเทพฯ' : 'BANGKOK'}
        </text>
      </g>
    </svg>

    {/* Inline legend overlay — top-right of canvas (iter3 spec) */}
    <aside class="tli-map__legend" aria-label={C.legendAriaLabel}>
      <div class="tli-map__legend__title">{C.composite}</div>
      <div class="tli-map__legend__strip" aria-hidden="true">
        <span class="tli-map__legend__cell score-bg-0"></span>
        <span class="tli-map__legend__cell score-bg-1"></span>
        <span class="tli-map__legend__cell score-bg-2"></span>
        <span class="tli-map__legend__cell score-bg-3"></span>
        <span class="tli-map__legend__cell score-bg-4"></span>
        <span class="tli-map__legend__cell tli-map__legend__cell--floored"></span>
      </div>
      <div class="tli-map__legend__scale" aria-hidden="true">
        <span>0</span>
        <span>50</span>
        <span>100</span>
        <span class="tli-map__legend__floor">{locale === 'th' ? 'ติดเพดาน' : 'floored'}</span>
      </div>
      <div class="tli-map__legend__coverage">
        <span class="tli-num">{withData}</span> / {totalRendered}
        <span>{locale === 'th' ? 'จังหวัดมีข้อมูล' : 'provinces with data'}</span>
      </div>
    </aside>

    {/* Tooltip — populated by the hover script */}
    <div class="tli-map__tooltip" role="tooltip" data-visible="false">
      <div class="tli-map__tooltip__row">
        <span class="tli-map__tooltip__name"></span>
        <span class="tli-map__tooltip__score tli-num"></span>
      </div>
      <div class="tli-map__tooltip__band"></div>
      <div class="tli-map__tooltip__cta">{C.clickToView}</div>
    </div>
  </div>
</div>

<script>
  // Hover/keyboard interaction for the choropleth. Vanilla JS — no framework.
  // Runs once per page load, finds every map instance.
  document.querySelectorAll<HTMLElement>('[data-component="tli-map"]').forEach((root) => {
    const tooltip = root.querySelector<HTMLElement>('.tli-map__tooltip');
    const tipName = tooltip?.querySelector<HTMLElement>('.tli-map__tooltip__name');
    const tipScore = tooltip?.querySelector<HTMLElement>('.tli-map__tooltip__score');
    const tipBand = tooltip?.querySelector<HTMLElement>('.tli-map__tooltip__band');
    const canvas = root.querySelector<HTMLElement>('.tli-map__canvas');
    if (!tooltip || !canvas || !tipName || !tipScore || !tipBand) return;

    const paths = root.querySelectorAll<SVGPathElement>('.tli-map__province:not(.tli-map__province--nodata)');

    function positionTooltip(target: SVGPathElement) {
      const canvasRect = canvas!.getBoundingClientRect();
      const targetRect = target.getBoundingClientRect();
      const x = targetRect.left - canvasRect.left + targetRect.width / 2;
      const y = targetRect.top - canvasRect.top - 4;
      tooltip!.style.left = `${x}px`;
      tooltip!.style.top = `${y}px`;
    }

    function show(target: SVGPathElement) {
      const ds = target.dataset;
      tipName!.textContent = ds.provinceName ?? '';
      tipScore!.textContent = ds.provinceScore ?? '';
      tipBand!.textContent = `${ds.provinceRegion ?? ''} · ${ds.provinceBand ?? ''}`;
      positionTooltip(target);
      tooltip!.dataset.visible = 'true';
      target.classList.add('tli-map__province--active');
    }

    function hide(target: SVGPathElement) {
      tooltip!.dataset.visible = 'false';
      target.classList.remove('tli-map__province--active');
    }

    paths.forEach((path) => {
      path.addEventListener('mouseenter', () => show(path));
      path.addEventListener('focus', () => show(path));
      path.addEventListener('mouseleave', () => hide(path));
      path.addEventListener('blur', () => hide(path));
      const locale = (document.documentElement.lang === 'th' ? 'th' : 'en');
      path.addEventListener('click', () => {
        const id = path.dataset.provinceId;
        if (id) window.location.href = `/${locale}/${id}/`;
      });
      path.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          const id = path.dataset.provinceId;
          if (id) window.location.href = `/${locale}/${id}/`;
        }
      });
    });
  });
</script>
