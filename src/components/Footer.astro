interface Props {
  locale: 'en' | 'th';
}
const { locale } = Astro.props;
const copy = locale === 'th'
  ? {
      tagline: 'ดัชนีคุณภาพการอยู่อาศัยระดับจังหวัดของประเทศไทย',
      methodology: 'ระเบียบวิธี',
      about: 'เกี่ยวกับ',
      licensing: 'การอนุญาต',
    }
  : {
      tagline: 'A research composite index for all 77 Thai provinces.',
      methodology: 'Methodology',
      about: 'About',
      licensing: 'Licensing',
    };
const base = locale === 'th' ? '/th' : '/en';
---
<footer class="tli-footer">
  <div class="tli-footer__inner">
    <p>{copy.tagline}</p>
    <nav class="tli-footer__nav" aria-label={locale === 'th' ? 'ลิงก์ส่วนท้าย' : 'Footer navigation'}>
      <a href={`${base}/methodology/`}>{copy.methodology}</a>
      <a href={`${base}/about/`}>{copy.about}</a>
      <a href={`${base}/licensing/`}>{copy.licensing}</a>
    </nav>
  </div>
</footer>
