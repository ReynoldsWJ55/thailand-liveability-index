interface Props {
  locale: 'en' | 'th';
}
const { locale } = Astro.props;
const copy = locale === 'th'
  ? {
      tagline: 'ดัชนีคุณภาพการอยู่อาศัยระดับจังหวัดของประเทศไทย',
      methodology: 'ระเบียบวิธี',
      sources: 'แหล่งข้อมูล',
      license: 'CC BY 4.0',
    }
  : {
      tagline: 'A research-grade composite index for all 77 Thai provinces.',
      methodology: 'Methodology',
      sources: 'Sources',
      license: 'CC BY 4.0',
    };
---
<footer class="tli-footer">
  <div class="tli-footer__inner">
    <p>{copy.tagline}</p>
    <p>
      <span class="tli-source">{copy.license}</span>
    </p>
  </div>
</footer>
