{
  "name": "thailand-liveability-index",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Thailand Liveability Index — public site source. A standalone, methodology-first liveability index for Thailand's 77 provinces with a sub-provincial zone overlay.",
  "keywords": [
    "thailand",
    "liveability",
    "livability",
    "liveability-index",
    "provinces",
    "score",
    "open-methodology",
    "open-data",
    "walkability",
    "air-quality",
    "tli"
  ],
  "author": {
    "name": "Will Reynolds",
    "email": "info@thailandliveabilityindex.com"
  },
  "license": "(MIT AND CC-BY-4.0)",
  "homepage": "https://thailandliveabilityindex.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ReynoldsWJ55/thailand-liveability-index.git"
  },
  "bugs": {
    "url": "https://github.com/ReynoldsWJ55/thailand-liveability-index/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "fetch-scores": "python3 scripts/fetch-scores.py",
    "gen-og": "node scripts/gen-og.mjs",
    "predev": "npm run fetch-scores",
    "dev": "astro dev",
    "prebuild": "npm run fetch-scores && npm run gen-og",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.2",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^5.18.1",
    "lucide-static": "^1.14.0"
  }
}
